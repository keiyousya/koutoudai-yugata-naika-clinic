---
import { getCollection } from "astro:content";
import ArticleIcon from "./ArticleIcon.astro";

const articles = (await getCollection("articles")).sort(
  (a, b) => a.data.order - b.data.order,
);
---

<section id="articles" class="section articles">
  <div class="container">
    <h2 class="section-title">病気について知る</h2>
    <div class="articles-grid">
      {articles.map((article) => (
        <a href={`/articles/${article.id}`} class="article-card">
          <h3 class="card-title">{article.data.title}</h3>
          <p class="card-title-en">{article.data.titleEn}</p>
          <div class="card-icon">
            <ArticleIcon icon={article.data.icon} size={56} />
          </div>
          <span class="card-more">詳しく見る →</span>
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .articles {
    background: white;
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .article-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: white;
    border: 2px solid var(--color-turquoise);
    border-radius: 20px;
    padding: 32px 24px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .article-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(62, 184, 200, 0.15);
  }

  .card-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-text);
    margin-bottom: 6px;
    line-height: 1.4;
  }

  .card-title-en {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    letter-spacing: 0.05em;
    margin-bottom: 24px;
  }

  .card-icon {
    color: var(--color-turquoise);
    margin-bottom: 24px;
  }

  .card-more {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-turquoise);
  }

  @media (max-width: 768px) {
    .articles {
      padding-top: 36px;
      padding-bottom: 36px;
    }

    .articles-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 12px;
    }

    .article-card {
      padding: 20px 12px;
      aspect-ratio: 3 / 4;
      justify-content: center;
    }

    .card-title {
      font-size: 0.95rem;
    }

    .card-title-en {
      font-size: 0.65rem;
      margin-bottom: 16px;
    }

    .card-icon :global(.article-icon) {
      width: 40px;
      height: 40px;
    }

    .card-icon {
      margin-bottom: 16px;
    }

    .card-more {
      font-size: 0.65rem;
    }
  }
</style>
