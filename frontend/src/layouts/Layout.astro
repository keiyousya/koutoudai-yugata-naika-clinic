---
import '@fontsource/m-plus-1p/400.css';
import '@fontsource/m-plus-1p/500.css';
import '@fontsource/m-plus-1p/700.css';
import brandFontUrl from '../fonts/noto-sans-jp-brand.woff2?url';
import FixedLineButton from '../components/FixedLineButton.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "仙台市で夜21時まで診療の内科クリニック。健診で再検査・要精密検査を指摘された方、仕事帰りに通院できます。心電図・超音波検査対応。勾当台公園駅徒歩1分、土日も診療。" } = Astro.props;

const siteUrl = "https://koutoudai-yugata-naika.clinic";
const currentPath = Astro.url.pathname;
const canonicalUrl = currentPath === "/" ? siteUrl : `${siteUrl}${currentPath}`;
const ogImage = `${siteUrl}/og-image.jpg`;

// 構造化データ（JSON-LD）- MedicalBusiness
const structuredData = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "@id": siteUrl,
  "name": "勾当台夕方内科クリニック",
  "alternateName": ["Koutoudai Yugata Naika Clinic", "仙台夜間内科", "仙台夜診療クリニック"],
  "description": description,
  "url": siteUrl,
  "logo": `${siteUrl}/apple-touch-icon.png`,
  "image": ogImage,
  "medicalSpecialty": ["InternalMedicine", "GeneralPractice"],
  "availableService": [
    {
      "@type": "MedicalProcedure",
      "name": "健康診断の再検査・精密検査",
      "description": "健診で指摘された項目の再検査や精密検査を夜間に受けられます"
    },
    {
      "@type": "MedicalProcedure",
      "name": "アフターピル（緊急避妊薬）処方",
      "description": "夜間・土日もアフターピルを処方。レボノルゲストレル1.5mg 11,000円（税込・診察料込）"
    },
    {
      "@type": "MedicalProcedure",
      "name": "性感染症（STD）検査",
      "description": "クラミジア・淋菌・梅毒・HIVの検査に対応"
    },
    {
      "@type": "MedicalProcedure",
      "name": "心電図検査",
      "description": "不整脈や心臓の異常を調べる検査"
    },
    {
      "@type": "MedicalProcedure",
      "name": "超音波検査（エコー検査）",
      "description": "腹部・甲状腺・頸動脈などの超音波検査"
    },
    {
      "@type": "MedicalProcedure",
      "name": "発熱外来",
      "description": "発熱症状のある方の診療（19時〜21時）"
    }
  ],
  "address": {
    "@type": "PostalAddress",
    "postalCode": "980-0803",
    "addressLocality": "仙台市青葉区",
    "addressRegion": "宮城県",
    "addressCountry": "JP",
    "streetAddress": "国分町3丁目8-1 勾当台ビル4階"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": 38.2682,
    "longitude": 140.8694
  },
  "areaServed": {
    "@type": "City",
    "name": "仙台市"
  },
  "priceRange": "保険診療",
  "currenciesAccepted": "JPY",
  "paymentAccepted": "健康保険",
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Wednesday", "Thursday", "Friday", "Saturday", "Sunday"],
      "opens": "17:00",
      "closes": "21:00"
    }
  ],
  "keywords": "仙台 夜間診療, 仙台 クリニック 夜, 健診 再検査 仙台, 仕事帰り 病院 仙台, 夜間 内科 仙台, 土日診療 仙台, 仙台 アフターピル, アフターピル 夜間 仙台, 緊急避妊 仙台",
  "slogan": "仕事帰りに通える夜間診療",
  "sameAs": []
};

// FAQ構造化データ
const faqStructuredData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "仙台で夜間に診療しているクリニックはありますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "勾当台夕方内科クリニックは仙台市青葉区で夜21時まで診療しています。勾当台公園駅から徒歩1分、仕事帰りに通院できます。水曜〜日曜の17時〜21時まで診療しています。"
      }
    },
    {
      "@type": "Question",
      "name": "健康診断で再検査と言われたのですが、仕事帰りに検査できますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "はい、当院では夜21時まで診療しているため、仕事帰りに再検査・精密検査を受けることができます。心電図検査や超音波検査（エコー）にも対応しています。土日も診療していますので、平日お忙しい方もご利用いただけます。"
      }
    },
    {
      "@type": "Question",
      "name": "土日も診療していますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "はい、土曜日・日曜日も17時〜21時まで診療しています。月曜・火曜・祝日は休診です。"
      }
    },
    {
      "@type": "Question",
      "name": "どのような検査ができますか？",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "心電図検査、超音波検査（腹部エコー、甲状腺エコー、頸動脈エコー）、血液検査などに対応しています。健康診断で異常を指摘された方の再検査・精密検査も行っています。"
      }
    }
  ]
};
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="google-site-verification" content="rRO1_K380rEa8DbtwGNE4SchqnFJB6Sdjjd-u7ovGcQ" />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content="ja_JP" />
    <meta property="og:site_name" content="勾当台夕方内科クリニック" />

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow" />
    <meta name="googlebot" content="index, follow" />
    <meta name="format-detection" content="telephone=no" />
    <meta name="theme-color" content="#1e3a5f" />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />


    <!-- Preconnect for critical resources -->
    <link rel="preconnect" href="https://koutoudai-reservation-api.kit-tamtam.workers.dev" crossorigin />
    <link rel="dns-prefetch" href="https://maps.googleapis.com" />

    <!-- Brand font (subset: クリニック名のみ) -->
    <link rel="preload" href={brandFontUrl} as="font" type="font/woff2" crossorigin />
    <style set:html={`
      @font-face {
        font-family: 'Noto Sans JP Brand';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url(${brandFontUrl}) format('woff2');
      }
    `} />

    <title>{title}</title>

    <!-- Structured Data (JSON-LD) -->
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script type="application/ld+json" set:html={JSON.stringify(faqStructuredData)} />

    <!-- Critical CSS for above-the-fold content -->
    <!-- レイアウトシフト防止用の最小限クリティカルCSS -->
    <style>
      *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
      html{scroll-behavior:smooth;overflow-x:clip}
      body{margin:0}
      .header{position:fixed;top:0;left:0;right:0;z-index:1000}
      .header-inner{display:flex;align-items:center;justify-content:space-between;height:60px}
      .hero{position:relative;min-height:100vh;display:flex;align-items:center;justify-content:center;overflow:hidden;padding-top:70px}
      @media(max-width:768px){.hero{min-height:calc(100vh - 20px);padding:100px 0 60px}}
    </style>
  </head>
  <body>
    <slot />
    <FixedLineButton />
  </body>
</html>

<style is:global>
  :root {
    /* Brand */
    --color-navy: #1e3a5f;
    --color-navy-light: #2a4a6e;
    --color-navy-medium: #4a6a8a;

    /* Pop Colors */
    --color-coral: #f08c5a;
    --color-coral-bg: #fff5eb;
    --color-turquoise: #3eb8c8;
    --color-turquoise-bg: #e8f6f8;

    /* Text */
    --color-text: #222;
    --color-text-secondary: #444;
    --color-text-muted: #555;

    /* Background */
    --color-bg: #fafafa;
    --color-bg-warm: #f9f6f3;
    --color-bg-blue: #f3f6f9;

    /* Border */
    --color-border: #e5e5e5;

    /* Fonts */
    --font-brand: "Noto Sans JP Brand", sans-serif;
  }

  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    scroll-behavior: smooth;
    overflow-x: clip;
    font-size: 22px;
  }

  body {
    font-family: "M PLUS 1p", -apple-system, BlinkMacSystemFont, "Hiragino Kaku Gothic ProN", "Hiragino Sans", Meiryo, sans-serif;
    line-height: 1.7;
    color: var(--color-text);
    background-color: var(--color-bg);
    overflow-x: clip;
    font-size: 22px;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    max-width: 100%;
    height: auto;
  }

  ul {
    list-style: none;
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .section {
    padding: 84px 0;
    scroll-margin-top: 32px;
  }

  .section-title {
    font-size: 1.5rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 48px;
    color: var(--color-navy);
    letter-spacing: 0.04em;
  }

  .section-title::after {
    content: "";
    display: block;
    width: 40px;
    height: 1px;
    background: var(--color-navy);
    margin: 16px auto 0;
    opacity: 0.3;
  }

  @media (max-width: 768px) {
    html {
      font-size: 18px;
    }

    body {
      font-size: 18px;
    }

    .section {
      padding: 60px 0;
    }

    .section-title {
      font-size: 1.3rem;
      margin-bottom: 36px;
    }
  }
</style>
