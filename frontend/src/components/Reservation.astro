---
import LineCta from "./LineCta.astro";
---

<section id="reservation" class="section reservation">
  <div class="container">
    <h2 class="section-title">ご予約</h2>
    <div class="reservation-content">
      <LineCta showIntro={true} />
      <p class="reservation-note">
        ※ 当院では紙の診察券は発行しておりません。<br />
        お友だち追加いただいたLINEアカウントが<br />診察券の代わりとなります。
      </p>
    </div>
  </div>
</section>

<style>
  .reservation {
    background: white;
  }

  .reservation-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .reservation-note {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-top: 28px;
  }
</style>
