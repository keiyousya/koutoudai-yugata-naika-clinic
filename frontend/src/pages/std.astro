---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import LineCta from "../components/LineCta.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="性感染症（STD）検査 | 勾当台夕方内科クリニック | 仙台市"
  description="仙台市で性感染症の検査を受けるなら。勾当台夕方内科クリニックでは夕方17時から夜21時まで、クラミジア・淋菌・梅毒・HIVの検査に対応。土日も診療。プライバシーに配慮した環境で検査を受けられます。"
>
  <Header />
  <main class="page-main">
    <PageHero
      label="STD Testing"
      title="性感染症（STD）検査"
      description="「検査を受けたいけど、日中は時間がない」「人目が気になる」——<br />当院では<strong>夕方17時から夜21時まで</strong>、性感染症の検査を行っています。<br />プライバシーに配慮した環境で、安心して検査を受けられます。"
    />

    <section class="page-section">
      <div class="container">
        <h2 class="page-section-title">検査できる性感染症</h2>
        <div class="std-grid">
          <div class="std-card">
            <h3 class="std-card-title">クラミジア</h3>
            <p class="std-card-description">
              最も多い性感染症のひとつ。自覚症状がないことも多く、放置すると不妊の原因になることがあります。
            </p>
            <p class="std-card-method">検査方法：尿検査</p>
          </div>
          <div class="std-card">
            <h3 class="std-card-title">淋菌（淋病）</h3>
            <p class="std-card-description">
              排尿時の痛みや膿が出ることがあります。クラミジアとの同時感染も多く見られます。
            </p>
            <p class="std-card-method">検査方法：尿検査</p>
          </div>
          <div class="std-card">
            <h3 class="std-card-title">梅毒</h3>
            <p class="std-card-description">
              近年、感染者数が増加しています。早期発見・早期治療が重要です。
            </p>
            <p class="std-card-method">検査方法：血液検査</p>
          </div>
          <div class="std-card">
            <h3 class="std-card-title">HIV</h3>
            <p class="std-card-description">
              早期発見により、適切な治療で通常の生活を送ることができます。定期的な検査をおすすめします。
            </p>
            <p class="std-card-method">検査方法：血液検査</p>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section bg-warm">
      <div class="container">
        <h2 class="page-section-title">こんな方におすすめ</h2>
        <ul class="recommend-list">
          <li>
            <span class="recommend-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            パートナーが変わった・新しいパートナーができた
          </li>
          <li>
            <span class="recommend-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            コンドームなしでの性行為があった
          </li>
          <li>
            <span class="recommend-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            排尿時の痛みや違和感がある
          </li>
          <li>
            <span class="recommend-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            パートナーが性感染症と診断された
          </li>
          <li>
            <span class="recommend-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"/>
              </svg>
            </span>
            定期的に検査を受けて安心したい
          </li>
        </ul>
      </div>
    </section>

    <section class="page-section">
      <div class="container">
        <h2 class="page-section-title">当院の特徴</h2>
        <ul class="feature-list">
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </span>
            <div>
              <strong>夕方17時〜夜21時まで診療</strong>
              <p>仕事帰りや夜間に検査を受けられます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <div>
              <strong>土日も診療</strong>
              <p>平日に時間が取れない方も週末に受診できます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
                <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
              </svg>
            </span>
            <div>
              <strong>プライバシーへの配慮</strong>
              <p>個室での診察・相談を行います。安心してご相談ください。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/>
                <polyline points="22 4 12 14.01 9 11.01"/>
              </svg>
            </span>
            <div>
              <strong>陽性の場合は治療まで対応</strong>
              <p>検査で陽性だった場合、そのまま治療を開始できます。</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <section class="page-section bg-blue">
      <div class="container">
        <h2 class="page-section-title">検査の流れ</h2>
        <ol class="flow-list">
          <li class="flow-item">
            <span class="flow-number">1</span>
            <div>
              <strong>ご来院・問診</strong>
              <p>症状や気になる点をお伺いします。</p>
            </div>
          </li>
          <li class="flow-item">
            <span class="flow-number">2</span>
            <div>
              <strong>検査</strong>
              <p>尿検査・血液検査を行います。</p>
            </div>
          </li>
          <li class="flow-item">
            <span class="flow-number">3</span>
            <div>
              <strong>結果説明</strong>
              <p>後日、結果をご説明します（数日〜1週間程度）。</p>
            </div>
          </li>
          <li class="flow-item">
            <span class="flow-number">4</span>
            <div>
              <strong>治療（必要な場合）</strong>
              <p>陽性の場合は、抗生剤などによる治療を行います。</p>
            </div>
          </li>
        </ol>
      </div>
    </section>

    <section class="page-cta">
      <div class="container">
        <LineCta lines={[
          "性感染症は早期発見・早期治療が大切です。",
          "少しでも気になることがあれば、",
          "お気軽にご相談ください。"
        ]} />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-section {
    padding: 80px 0;
  }

  .page-section.bg-warm {
    background: var(--color-bg-warm);
  }

  .page-section.bg-blue {
    background: var(--color-bg-blue);
  }

  .page-section-title {
    font-size: 1.3rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 40px;
    color: var(--color-navy);
  }

  .std-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 24px;
  }

  .std-card {
    background: var(--color-bg-blue);
    border-radius: 4px;
    padding: 28px;
    border-left: 3px solid var(--color-navy);
  }

  .std-card-title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .std-card-description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .std-card-method {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    padding-top: 12px;
    border-top: 1px solid var(--color-border);
  }

  .recommend-list {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .recommend-list li {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .recommend-icon {
    flex-shrink: 0;
    color: var(--color-navy);
  }

  .feature-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 24px;
    background: var(--color-bg-warm);
    border-radius: 4px;
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-navy-medium);
    width: 32px;
    height: 32px;
  }

  .feature-item strong {
    display: block;
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .feature-item p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .flow-list {
    max-width: 640px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .flow-item {
    display: flex;
    align-items: flex-start;
    gap: 20px;
    background: white;
    padding: 20px;
    border-radius: 4px;
  }

  .flow-number {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    background: var(--color-navy);
    color: white;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .flow-item strong {
    display: block;
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .flow-item p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .page-cta {
    background: white;
    padding: 64px 0;
    text-align: center;
  }

  .page-cta-text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 2;
    margin-bottom: 28px;
  }

  .page-cta-button {
    display: inline-block;
    background: var(--color-navy);
    color: white;
    padding: 16px 48px;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .page-cta-button:hover {
    background: var(--color-navy-light);
  }

  .page-cta-button.line-button {
    background: #06C755;
  }

  .page-cta-button.line-button:hover {
    background: #05b34c;
  }

  .page-cta-note {
    margin-top: 14px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .page-section {
      padding: 60px 0;
    }

    .std-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
