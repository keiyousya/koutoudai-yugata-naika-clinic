---
interface Props {
  lines?: string[];
  showIntro?: boolean;
}

const { lines = [], showIntro = false } = Astro.props;
const lineAddFriendUrl = "https://lin.ee/o8VUXOX";
---

<div class="line-cta">
  {showIntro && (
    <p class="line-cta-intro">
      当院ではLINEからのご予約を<br />お願いしております。
    </p>
  )}
  {lines.length > 0 && (
    <p class="line-cta-text">
      {lines.map((line) => (
        <span class="cta-line">{line}</span>
      ))}
    </p>
  )}
  <a href={lineAddFriendUrl} target="_blank" rel="noopener noreferrer" class="line-cta-button">
    <svg class="line-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor">
      <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
    </svg>
    LINE予約はこちら
  </a>
  <p class="line-cta-note">
    友だち追加後、トーク画面よりご予約ください<br />
    予約なしでも受診いただけます
  </p>
</div>

<style>
  .line-cta {
    text-align: center;
  }

  .line-cta-intro {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 24px;
  }

  .line-cta-text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 2;
    margin-bottom: 28px;
  }

  .cta-line {
    display: block;
  }

  .line-cta-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    background: #06C755;
    color: white;
    padding: 16px 48px;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .line-cta-button:hover {
    background: #05b34c;
  }

  .line-icon {
    width: 24px;
    height: 24px;
  }

  .line-cta-note {
    margin-top: 16px;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }
</style>
