    opacity: 1;
  }

  .news-link {
    text-align: center;
    margin-top: 20px;
  }

  .news-link a {
    color: var(--color-turquoise);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .news-link a:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .news {
      padding-top: 36px;
      padding-bottom: 36px;
    }

    .news-item-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding: 14px 16px;
    }

    .news-date {
