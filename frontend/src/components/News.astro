---
import { newsItems } from "../data/news";
---

<section id="news" class="section news">
  <div class="container">
    <h2 class="section-title">お知らせ</h2>
    <div class="news-content">
      <ul class="news-list">
        {newsItems.slice(0, 3).map((item) => (
          <li class={`news-item ${item.isImportant ? "important" : ""}`}>
            <a href={`/news/${item.slug}`} class="news-item-link">
              <span class="news-date">{item.date}</span>
              <span class="news-text">{item.content}</span>
              <span class="news-arrow">
                <span class="arrow-text">詳しくはこちら</span>
                <span class="arrow-symbol">→</span>
              </span>
            </a>
          </li>
        ))}
      </ul>
      <div class="news-link">
        <a href="/news">すべてのお知らせを見る →</a>
      </div>
    </div>
  </div>
</section>

<style>
  .news {
    background: white;
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .news-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .news-item {
    background: var(--color-turquoise-bg);
    border-radius: 16px;
    transition: background 0.2s;
  }

  .news-item.important {
    background: var(--color-turquoise-bg);
  }

  .news-item:hover {
    background: rgba(62, 184, 200, 0.25);
  }

  .news-item-link {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 18px 24px;
    text-decoration: none;
    color: inherit;
  }

  .news-date {
    flex-shrink: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .news-text {
    flex: 1;
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .news-item.important .news-text {
    color: var(--color-navy);
    font-weight: 500;
  }

  .news-arrow {
    flex-shrink: 0;
    color: var(--color-turquoise);
    opacity: 0.6;
    transition: opacity 0.2s;
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .arrow-text {
    display: none;
    font-size: 0.85rem;
    font-weight: 500;
  }

  .arrow-symbol {
    font-size: 1rem;
  }

  .news-item:hover .news-arrow {
    opacity: 1;
  }

  .news-link {
    text-align: center;
    margin-top: 20px;
  }

  .news-link a {
    color: var(--color-turquoise);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .news-link a:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .news {
      padding-top: 36px;
      padding-bottom: 36px;
    }

    .news-item-link {
      flex-direction: column;
      align-items: flex-start;
      gap: 8px;
      padding: 14px 16px;
    }

    .news-date {
      font-size: 0.8rem;
    }

    .news-text {
      font-size: 0.9rem;
    }

    .news-arrow {
      margin-top: 4px;
      opacity: 1;
      align-self: flex-end;
    }

    .arrow-text {
      display: inline;
    }
  }
</style>
