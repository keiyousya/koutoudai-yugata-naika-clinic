---
---

<section id="access" class="section access">
  <div class="container">
    <h2 class="section-title">アクセス</h2>
    <div class="access-content">
      <div class="access-info">
        <div class="clinic-name">
          <h3>勾当台夕方内科クリニック</h3>
        </div>

        <dl class="info-list">
          <div class="info-row">
            <dt>住所</dt>
            <dd>
              〒980-0803<br />
              宮城県仙台市青葉区国分町3丁目8-1<br />
              勾当台ビル 4階
            </dd>
          </div>
          <div class="info-row">
            <dt>最寄駅</dt>
            <dd>
              仙台市地下鉄南北線<br />
              <strong>勾当台公園駅</strong> 徒歩2分
            </dd>
          </div>
          <div class="info-row">
            <dt>電話番号</dt>
            <dd>
              <a href="tel:022-393-8689" class="tel">022-393-8689</a>
            </dd>
          </div>
        </dl>

      </div>

      <div class="access-map">
        <div class="map-container" id="mapContainer">
          <!-- Static map placeholder - loads iframe on interaction -->
          <div class="map-placeholder" id="mapPlaceholder">
            <div class="map-placeholder-content">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="map-icon">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path>
                <circle cx="12" cy="10" r="3"></circle>
              </svg>
              <span class="map-placeholder-text">勾当台公園駅 徒歩2分</span>
              <button class="map-load-btn" type="button">
                地図を表示
              </button>
            </div>
          </div>
          <!-- Interactive iframe - loaded on demand -->
          <iframe
            id="mapIframe"
            data-src="https://www.google.com/maps/embed/v1/place?key=AIzaSyBFw0Qbyq9zTFTd-tUY6dZWTgaQzuU17R8&q=勾当台夕方内科クリニック&zoom=17"
            width="100%"
            height="100%"
            style="border:0; display:none;"
            allowfullscreen=""
            referrerpolicy="no-referrer-when-downgrade"
            title="勾当台夕方内科クリニックの地図"></iframe>
        </div>
        <a
          href="https://maps.google.com/?q=勾当台夕方内科クリニック"
          target="_blank"
          rel="noopener noreferrer"
          class="map-link"
        >
          Google マップで開く →
        </a>
      </div>
    </div>

    <div class="access-extra">
      <div class="directions">
        <h4>ビルへの入り方</h4>
        <ol class="directions-list">
          <li>
            <span class="step-num">1</span>
            <span>勾当台ビルの看板がある入り口からお入りください</span>
          </li>
          <li>
            <span class="step-num">2</span>
            <span>エレベーターで4階までお上がりください</span>
          </li>
          <li>
            <span class="step-num">3</span>
            <span>エレベーターを降りて、すぐ左手に当院の扉がございます</span>
          </li>
        </ol>
      </div>

      <div class="parking">
        <h4>駐車場のご案内</h4>
        <p class="parking-lead">
          当院に専用駐車場はございませんが、<a href="https://machi-kuru.com/ticket" target="_blank" rel="noopener noreferrer">まちくるチケット</a>加盟のため、提携駐車場をご利用いただけます。
        </p>
        <dl class="parking-details">
          <div class="parking-row">
            <dt>最寄りの提携駐車場</dt>
            <dd><a href="https://machi-kuru.com/pa/405" target="_blank" rel="noopener noreferrer">勾当台公園地下駐車場</a><span class="parking-note">（20分100円）</span></dd>
          </div>
          <div class="parking-row">
            <dt>チケットお渡し</dt>
            <dd><strong>受付に駐車券をご提示ください。</strong>院内滞在時間に応じて、20分100円分のチケットをお渡しします<br /><span class="parking-note">（上限：1時間分 / 300円相当）</span></dd>
          </div>
        </dl>
        <p class="parking-sub-note">
          ※ 勾当台公園地下駐車場以外のまちくるチケット提携駐車場をご利用の場合も、同額分のお渡しとなります。
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .access {
    background: white;
  }

  .access-content {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
    align-items: start;
  }

  .clinic-name h3 {
    font-size: 1.15rem;
    color: var(--color-navy);
    margin-bottom: 24px;
    padding-bottom: 14px;
    border-bottom: 1px solid var(--color-border);
  }

  .info-list {
    margin-bottom: 36px;
  }

  .info-row {
    display: flex;
    align-items: baseline;
    padding: 18px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .info-row:last-child {
    border-bottom: none;
  }

  .info-row dt {
    width: 100px;
    flex-shrink: 0;
    font-weight: 500;
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .info-row dd {
    color: #444;
    line-height: 1.8;
  }

  .info-row dd strong {
    color: var(--color-navy);
  }

  .tel {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .tel:hover {
    color: var(--color-orange);
  }

  .access-extra {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 36px;
  }

  .directions {
    background: var(--color-bg-warm);
    padding: 24px;
    border-radius: 4px;
  }

  .directions h4 {
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 18px;
  }

  .directions-list {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .directions-list li {
    display: flex;
    align-items: flex-start;
    gap: 12px;
    font-size: 0.9rem;
    color: var(--color-text-secondary);
  }

  .step-num {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.6em;
    height: 1.6em;
    background: var(--color-navy);
    color: white;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 50%;
    flex-shrink: 0;
    margin-top: 0.15em;
  }

  .parking {
    background: var(--color-bg-blue);
    padding: 24px;
    border-radius: 4px;
  }

  .parking h4 {
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 14px;
  }

  .parking-lead {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .parking-lead a {
    color: var(--color-navy-medium);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .parking-lead a:hover {
    color: var(--color-navy);
  }

  .parking-details {
    margin-bottom: 12px;
  }

  .parking-row {
    display: flex;
    align-items: baseline;
    padding: 14px 0;
    border-bottom: 1px solid rgba(0, 0, 0, 0.06);
    gap: 16px;
  }

  .parking-row:last-child {
    border-bottom: none;
  }

  .parking-row dt {
    flex-shrink: 0;
    white-space: nowrap;
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .parking-row dd {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .parking-row dd a {
    color: var(--color-navy-medium);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .parking-row dd a:hover {
    color: var(--color-navy);
  }

  .parking-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .parking-sub-note {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .map-container {
    width: 100%;
    height: 350px;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    position: relative;
  }

  .map-placeholder {
    position: relative;
    width: 100%;
    height: 100%;
    background: var(--color-navy);
    cursor: pointer;
  }

  .map-placeholder-content {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
    text-align: center;
  }

  .map-icon {
    color: #f5c57a;
  }

  .map-placeholder-text {
    font-size: 0.95rem;
    color: #fff;
    font-weight: 500;
  }

  .map-load-btn {
    padding: 8px 20px;
    background: rgba(255, 255, 255, 0.15);
    color: white;
    border: 1px solid rgba(255, 255, 255, 0.4);
    border-radius: 3px;
    cursor: pointer;
    font-size: 0.9rem;
    font-weight: 400;
    transition: background 0.2s;
  }

  .map-load-btn:hover {
    background: rgba(255, 255, 255, 0.25);
  }

  .map-placeholder.hidden {
    display: none;
  }

  .map-link {
    display: inline-block;
    margin-top: 14px;
    font-size: 0.9rem;
    color: var(--color-navy-medium);
    font-weight: 400;
    transition: color 0.2s;
  }

  .map-link:hover {
    color: var(--color-navy);
  }

  @media (max-width: 768px) {
    .access-content {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .info-row {
      flex-direction: column;
      gap: 8px;
    }

    .info-row dt {
      width: auto;
    }

    .access-extra {
      gap: 12px;
      margin-top: 28px;
    }

    .parking-row {
      flex-direction: column;
      gap: 4px;
    }

    .parking-row dt {
      width: auto;
    }

    .map-container {
      height: 280px;
    }
  }
</style>

<script>
  const mapPlaceholder = document.getElementById("mapPlaceholder");
  const mapIframe = document.getElementById("mapIframe") as HTMLIFrameElement;
  const mapContainer = document.getElementById("mapContainer");

  function loadInteractiveMap() {
    if (mapIframe && mapPlaceholder && !mapIframe.src) {
      const src = mapIframe.dataset.src;
      if (src) {
        mapIframe.src = src;
        mapIframe.style.display = "block";
        mapPlaceholder.classList.add("hidden");
      }
    }
  }

  // セクションが画面に近づいた時だけ地図を読み込む（未使用JS削減）
  if (mapContainer && "IntersectionObserver" in window) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            loadInteractiveMap();
            observer.disconnect();
          }
        });
      },
      { rootMargin: "300px" }
    );
    observer.observe(mapContainer);
  } else {
    // フォールバック: IntersectionObserver非対応ブラウザ
    loadInteractiveMap();
  }
</script>
