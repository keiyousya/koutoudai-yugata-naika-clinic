---
import { Image } from "astro:assets";
import TwilightBackground from "./TwilightBackground.astro";
import interiorImage01 from "../assets/interior01.jpeg";
import interiorImage02 from "../assets/interior02.jpeg";
import interiorImage03 from "../assets/interior03.jpeg";
---

<section class="hero">
  <div class="hero-slideshow" id="heroSlideshow">
    <div class="hero-slide-wrapper">
      <Image src={interiorImage01} alt="" width={1600} class="hero-slide" />
    </div>
    <div class="hero-slide-wrapper">
      <Image src={interiorImage02} alt="" width={1600} class="hero-slide" />
    </div>
    <div class="hero-slide-wrapper">
      <Image src={interiorImage03} alt="" width={1600} class="hero-slide" />
    </div>
  </div>
  <div class="hero-content container">
    <p class="hero-closure-label">本日は臨時休診です</p>
    <p class="hero-catchphrase">夜21時まで診療｜土日も受診できる内科</p>
    <h1 class="hero-title">
      <span class="hero-title-main">勾当台夕方内科<br class="sp-br" />クリニック</span>
    </h1>
    <div class="hero-schedule">
      <table class="hero-schedule-table">
        <thead>
          <tr>
            <th class="schedule-label">診療時間</th>
            <th>月</th>
            <th>火</th>
            <th>水</th>
            <th>木</th>
            <th>金</th>
            <th class="weekend">土</th>
            <th class="weekend">日</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="schedule-time">14-17時</td>
            <td class="closed">―</td>
            <td class="closed">―</td>
            <td class="closed">―</td>
            <td class="closed">―</td>
            <td class="closed">―</td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
          </tr>
          <tr class="fever-row">
            <td class="schedule-time">17-21時</td>
            <td class="open"><span class="dot"></span></td>
            <td class="closed">―</td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
          </tr>
        </tbody>
      </table>
      <p class="hero-schedule-note"><strong>【休診日】火曜日・祝日</strong><span class="note-sub">※最終受付 20:45</span></p>
    </div>
    <p class="hero-access">勾当台公園駅から徒歩2分</p>
  </div>
  <!-- TODO: 8/1に復元 — 臨時休診期間中は非表示 -->
  <!-- <a href="/availability" class="availability-banner">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
      <line x1="16" y1="2" x2="16" y2="6"/>
      <line x1="8" y1="2" x2="8" y2="6"/>
      <line x1="3" y1="10" x2="21" y2="10"/>
    </svg>
    <span>本日の予約状況を確認</span>
  </a> -->
  <a href="/news/2026-07-16" class="availability-banner">
    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <span>臨時休診のお知らせ（7/16〜7/31）</span>
  </a>
  <TwilightBackground />
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 172px;
    padding-bottom: 0;
    isolation: isolate;
    background: var(--color-navy);
  }

  .hero-slideshow {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-slide-wrapper {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .hero-slide-wrapper.active {
    opacity: 1;
  }

  .hero-slide-wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(30, 58, 95, 0.4);
  }

  .hero-slide {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes panLeftToRight {
    0% {
      object-position: 0% center;
    }
    100% {
      object-position: 100% center;
    }
  }

  .hero-content {
    text-align: center;
    z-index: 1;
  }

  .hero-closure-label {
    display: inline-block;
    padding: 6px 24px;
    background: #d03030;
    color: #fff;
    font-size: 1.1rem;
    font-weight: 700;
    border-radius: 6px;
    letter-spacing: 0.1em;
    margin-bottom: 20px;
  }

  .hero-catchphrase {
    font-size: 1.15rem;
    color: #ffffff;
    margin-bottom: 20px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
  }

  .hero-title {
    margin-bottom: 32px;
  }

  .hero-title-main {
    display: block;
    font-family: var(--font-brand);
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.06em;
    line-height: 1.4;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
  }

  .sp-br {
    display: none;
  }

  .hero-schedule {
    margin: 0 auto 32px;
    max-width: 520px;
    background: #2a4e78;
    padding: 16px 16px 18px;
    border-radius: 6px;
  }

  .hero-schedule-table {
    width: 100%;
    border-collapse: collapse;
  }

  /* ヘッダー行: 白背景（紺の内側にマージンを持つ） */
  .hero-schedule-table thead tr {
    background: white;
  }

  .hero-schedule-table th {
    padding: 8px 0;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-navy);
    vertical-align: middle;
  }

  .hero-schedule-table th.weekend {
    color: #d03030;
  }

  .schedule-label {
    width: 130px;
    letter-spacing: 0.25em !important;
  }

  /* データ行: 紺背景・白文字 */
  .hero-schedule-table td {
    padding: 5px 0;
    text-align: center;
    vertical-align: middle;
    color: white;
  }

  .schedule-time {
    font-weight: 700;
    font-size: 0.8rem;
    letter-spacing: 0.03em;
    width: 110px;
  }

  .hero-schedule-table td.closed {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem !important;
    font-weight: 400;
  }

  .fever-row td {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .dot {
    display: inline-block;
    width: 18px;
    height: 18px;
    background: #e8a04c;
    border-radius: 50%;
  }

  /* 休診日注記: 紺背景の中 */
  .hero-schedule-note {
    padding: 8px 16px 0;
    margin-top: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.15);
    font-size: 0.8rem;
    font-weight: 500;
    color: #fff;
    text-align: center;
  }

  .hero-schedule-note strong {
    font-weight: 700;
  }

  .note-sub {
    font-size: 0.72rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.7);
    margin-left: 10px;
  }

  .hero-access {
    font-size: 0.9rem;
    color: #ffffff;
    margin-bottom: 36px;
    font-weight: 500;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 20px);
      padding: 180px 0 60px;
    }

    .hero-closure-label {
      font-size: 0.95rem;
      padding: 5px 18px;
    }

    .hero-catchphrase {
      font-size: 0.9rem;
    }

    .hero-title-main {
      font-size: 1.6rem;
    }

    .hero-slide {
      object-position: 100% center;
      animation: panLeftToRight 6.5s linear forwards;
    }

    .hero-schedule {
      max-width: 100%;
      padding: 10px 8px 12px;
    }

    .hero-schedule-table th {
      padding: 7px 0;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
    }

    .hero-schedule-table td {
      padding: 4px 0;
    }

    .schedule-label {
      width: auto;
      padding: 0 6px;
      letter-spacing: 0.08em !important;
    }

    .schedule-time {
      width: auto;
      padding: 0 4px;
      font-size: 0.72rem;
      white-space: nowrap;
    }

    .dot {
      width: 14px;
      height: 14px;
    }

    .hero-schedule-table td.closed {
      font-size: 0.8rem !important;
    }

    .hero-schedule-note {
      font-size: 0.72rem;
      padding: 10px 6px 0;
    }

    .hero-access {
      font-size: 0.9rem;
    }

  }

  @media (max-width: 480px) {
    .sp-br {
      display: inline;
    }
  }

  .availability-banner {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 24px;
    background: rgba(208, 48, 48, 0.8);
    border: 1px solid rgba(255, 255, 255, 0.5);
    border-radius: 24px;
    text-decoration: none;
    transition: all 0.2s;
    animation: pulse-glow 2s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { box-shadow: 0 0 0 0 rgba(208, 48, 48, 0.4); }
    50% { box-shadow: 0 0 16px 4px rgba(208, 48, 48, 0.3); }
  }

  .availability-banner:hover {
    background: rgba(208, 48, 48, 0.95);
    border-color: rgba(255, 255, 255, 0.7);
  }

  .availability-banner svg {
    color: white;
    flex-shrink: 0;
  }

  .availability-banner span {
    color: white;
    font-size: 0.9rem;
    font-weight: 600;
    white-space: nowrap;
  }

  @media (max-width: 768px) {
    .availability-banner {
      bottom: 24px;
      padding: 10px 20px;
      gap: 6px;
    }

    .availability-banner svg {
      width: 16px;
      height: 16px;
    }

    .availability-banner span {
      font-size: 0.82rem;
    }
  }
</style>

<script>
  const wrappers = document.querySelectorAll<HTMLElement>(".hero-slide-wrapper");
  const twilight = document.querySelector<HTMLElement>(".twilight-bg");
  const stars = document.querySelector<HTMLElement>(".stars");
  const shootingStars = document.querySelectorAll<HTMLElement>(".shooting-star");
  const skyline = document.querySelector<HTMLElement>(".skyline");

  if (wrappers.length > 0) {
    let current = -1; // -1 = twilight background
    const total = wrappers.length;
    const interval = 5000;

    function showTwilight() {
      wrappers.forEach((w) => w.classList.remove("active"));
      if (twilight) twilight.style.opacity = "1";
      if (stars) stars.style.opacity = "1";
      shootingStars.forEach((s) => (s.style.opacity = ""));
      if (skyline) skyline.style.opacity = "";
    }

    function showSlide(index: number) {
      wrappers.forEach((w) => w.classList.remove("active"));
      if (twilight) twilight.style.opacity = "0";
      if (stars) stars.style.opacity = "0";
      shootingStars.forEach((s) => (s.style.opacity = "0"));
      if (skyline) skyline.style.opacity = "0";

      // アニメーションをリセット
      const slide = wrappers[index].querySelector<HTMLElement>(".hero-slide");
      if (slide) {
        slide.style.animation = "none";
        slide.offsetHeight; // reflowを強制
        slide.style.animation = "";
      }

      wrappers[index].classList.add("active");
    }

    // Start with twilight
    showTwilight();

    // 最初の夕方背景は1秒だけ表示
    setTimeout(() => {
      current = 0;
      showSlide(current);

      setInterval(() => {
        current++;
        if (current >= total) {
          current = -1;
          showTwilight();
        } else {
          showSlide(current);
        }
      }, interval);
    }, 200);
  }

</script>
