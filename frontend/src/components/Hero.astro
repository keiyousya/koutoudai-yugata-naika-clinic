---
import TwilightBackground from "./TwilightBackground.astro";
---

<section class="hero">
  <div class="hero-content container">
    <p class="hero-catchphrase">夜21時まで診療｜土日も受診できる内科</p>
    <h1 class="hero-title">
      <span class="hero-title-main">勾当台夕方<br class="sp-br" />内科クリニック</span>
    </h1>
    <div class="opening-notice">
      <span class="opening-badge">開院準備中</span>
      <span class="opening-date">2026年4月 開院予定</span>
    </div>
    <div class="hero-schedule">
      <table class="hero-schedule-table">
        <thead>
          <tr>
            <th class="schedule-label">診療時間</th>
            <th>月</th>
            <th>火</th>
            <th>水</th>
            <th>木</th>
            <th>金</th>
            <th class="weekend">土</th>
            <th class="weekend">日</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="schedule-time">17:00 - 21:00</td>
            <td class="closed">―</td>
            <td class="closed">―</td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
          </tr>
        </tbody>
      </table>
      <p class="hero-schedule-note">【休診日】月曜日・火曜日・祝日</p>
    </div>
    <p class="hero-access">勾当台公園駅から徒歩2分</p>
    <!-- <a href="#reservation" class="hero-cta">ご予約・お問い合わせ</a> -->
  </div>
  <a href="/#recruit" class="recruit-banner">
    <span class="recruit-label">スタッフ募集</span>
    <span class="recruit-text">受付事務を募集しています</span>
  </a>
  <TwilightBackground />
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 80px;
    padding-bottom: 0;
    isolation: isolate;
    background: var(--color-navy);
  }

  .hero-content {
    text-align: center;
    z-index: 1;
  }

  .hero-catchphrase {
    font-size: 1.15rem;
    color: #ffffff;
    margin-bottom: 20px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
  }

  .hero-title {
    margin-bottom: 32px;
  }

  .opening-notice {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .opening-badge {
    display: inline-block;
    padding: 5px 14px;
    background: rgba(255, 255, 255, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.5);
    color: #ffffff;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 3px;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 4px rgba(0, 0, 0, 0.3);
  }

  .opening-date {
    font-size: 1rem;
    color: #ffffff;
    font-weight: 600;
    letter-spacing: 0.04em;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
  }

  .hero-title-main {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.06em;
    line-height: 1.4;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
  }

  .sp-br {
    display: none;
  }

  .hero-schedule {
    margin: 0 auto 32px;
    max-width: 520px;
    background: #2a4e78;
    padding: 16px 16px 18px;
    border-radius: 6px;
  }

  .hero-schedule-table {
    width: 100%;
    border-collapse: collapse;
  }

  /* ヘッダー行: 白背景（紺の内側にマージンを持つ） */
  .hero-schedule-table thead tr {
    background: white;
  }

  .hero-schedule-table th {
    padding: 8px 0;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-navy);
    vertical-align: middle;
  }

  .hero-schedule-table th.weekend {
    color: #d03030;
  }

  .schedule-label {
    width: 130px;
    letter-spacing: 0.25em !important;
  }

  /* データ行: 紺背景・白文字 */
  .hero-schedule-table td {
    padding: 10px 0;
    text-align: center;
    vertical-align: middle;
    color: white;
  }

  .schedule-time {
    font-weight: 700;
    font-size: 0.85rem !important;
    letter-spacing: 0.03em;
    width: 120px;
  }

  .hero-schedule-table td.closed {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem !important;
    font-weight: 400;
  }

  .dot {
    display: inline-block;
    width: 18px;
    height: 18px;
    background: #e8a04c;
    border-radius: 50%;
  }

  /* 休診日注記: 紺背景の中 */
  .hero-schedule-note {
    padding: 0 16px;
    margin-top: 0;
    font-size: 0.8rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  .note-sub {
    font-size: 0.9rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    margin-left: 6px;
  }

  .hero-access {
    font-size: 0.9rem;
    color: #ffffff;
    margin-bottom: 36px;
    font-weight: 500;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
  }

  .hero-cta {
    display: inline-block;
    padding: 14px 40px;
    background: var(--color-orange);
    color: white;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 4px;
    transition: opacity 0.2s;
    letter-spacing: 0.03em;
  }

  .hero-cta:hover {
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 20px);
      padding: 180px 0 60px;
    }

    .hero-catchphrase {
      font-size: 0.9rem;
    }

    .hero-title-main {
      font-size: 1.6rem;
    }

    .opening-notice {
      gap: 8px;
      margin-bottom: 16px;
    }

    .opening-badge {
      font-size: 0.9rem;
      padding: 4px 10px;
    }

    .opening-date {
      font-size: 0.9rem;
    }

    .hero-schedule {
      max-width: 100%;
      padding: 10px 8px 12px;
    }

    .hero-schedule-table th {
      padding: 7px 0;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
    }

    .hero-schedule-table td {
      padding: 8px 0;
    }

    .schedule-label {
      width: auto;
      padding: 0 8px;
      letter-spacing: 0.12em !important;
    }

    .schedule-time {
      width: auto;
      padding: 0 8px;
      font-size: 0.9rem !important;
      white-space: nowrap;
    }

    .dot {
      width: 14px;
      height: 14px;
    }

    .hero-schedule-table td.closed {
      font-size: 0.9rem !important;
    }

    .hero-schedule-note {
      font-size: 0.9rem;
      padding: 0 8px;
    }

    .hero-access {
      font-size: 0.9rem;
    }

    .hero-cta {
      padding: 12px 32px;
      font-size: 0.9rem;
    }
  }

  @media (max-width: 400px) {
    .sp-br {
      display: inline;
    }
  }

  .recruit-banner {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 18px;
    width: fit-content;
    max-width: min(90%, 1100px);
    padding: 18px 36px;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: opacity 0.2s;
  }

  .recruit-banner:hover {
    opacity: 0.9;
  }

  .recruit-label {
    display: inline-block;
    padding: 5px 12px;
    background: var(--color-orange);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  .recruit-text {
    color: var(--color-navy);
    font-size: 0.82rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .recruit-banner {
      gap: 10px;
      padding: 10px 16px;
      width: 90%;
    }

    .recruit-label {
      font-size: 0.65rem;
      padding: 4px 10px;
    }

    .recruit-text {
      font-size: 0.7rem;
    }
  }
</style>
