---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import TwilightBackground from "../components/TwilightBackground.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="予約状況 | 勾当台夕方内科クリニック"
  description="本日・明日の予約空き状況をリアルタイムで確認できます。仙台で夜21時まで診療、勾当台公園駅徒歩2分。"
>
  <Header />
  <main class="page-main">
    <div class="page-header">
      <div class="container">
        <p class="page-header-label">Availability</p>
        <h1 class="page-title">予約状況</h1>
      </div>
      <TwilightBackground />
    </div>

    <section class="section availability">
      <div class="container">
        <div class="availability-topbar">
          <div class="day-tabs" id="dayTabs">
            <span class="day-tab-indicator" aria-hidden="true"></span>
            <button class="day-tab active" type="button" data-offset="0">本日</button>
            <button class="day-tab" type="button" data-offset="1">明日</button>
          </div>
          <div class="last-updated">
            <span id="lastUpdated">--/-- --:--:--</span> 時点
          </div>
        </div>

        <div class="day-viewport">
          <div class="day-track" id="dayTrack">
            {[0, 1].map((offset) => (
              <div class="day-panel" data-offset={offset}>
                <div class="availability-header">
                  <span class="date-label">
                    <span class="date-icon-badge">
                      <svg class="date-icon" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                        <rect x="3" y="4" width="18" height="18" rx="2"></rect>
                        <line x1="3" y1="10" x2="21" y2="10"></line>
                        <line x1="8" y1="2" x2="8" y2="6"></line>
                        <line x1="16" y1="2" x2="16" y2="6"></line>
                      </svg>
                    </span>
                    {offset === 0 ? "本日の診療" : "明日の診療"}
                  </span>
                  <div class="date-row">
                    <span class="date-value">読み込み中...</span>
                    <span class="date-hours"></span>
                  </div>
                </div>

                <div class="status-message">
                  <div class="loading">予約状況を読み込んでいます...</div>
                </div>

                <div class="slots-container" style="display: none;">
                  <div class="slots-grid all-slots"></div>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="hours-note" id="hoursNote">
          <div class="hours-card hours-card--general">
            <span class="hours-dot"></span>
            <div class="hours-card-body">
              <span class="hours-card-label">一般診療</span>
              <span class="hours-card-time" data-kind="general">--</span>
            </div>
          </div>
          <div class="hours-card hours-card--fever">
            <span class="hours-dot"></span>
            <div class="hours-card-body">
              <span class="hours-card-label">発熱外来</span>
              <span class="hours-card-time" data-kind="fever">--</span>
            </div>
          </div>
        </div>

        <div class="availability-legend" id="availabilityLegend">
          <div class="legend-item">
            <span class="legend-badge available">○</span>
            <span>予約可能</span>
          </div>
          <div class="legend-item">
            <span class="legend-badge unavailable">×</span>
            <span>満席</span>
          </div>
          <div class="legend-item">
            <span class="legend-badge past">-</span>
            <span>受付終了</span>
          </div>
        </div>

        <div class="availability-notes" id="availabilityNotes">
          <p>※ 実際の予約受付状況と若干のタイムラグが生じる場合があります。</p>
          <p>※ 予約はLINEからお願いいたします。</p>
        </div>

        <div class="reservation-cta" id="reservationCta">
          <a href="https://line.me/R/ti/p/@koutoudai-yugata-naika" class="line-button" target="_blank" rel="noopener noreferrer">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.282.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
            LINEで予約する
          </a>
        </div>

        <div class="detail-back">
          <a href="/" class="back-button">ホームに戻る</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style is:global>
  .page-header {
    position: relative;
    padding: 120px 0 60px;
    background: var(--color-navy);
    color: white;
    text-align: center;
    overflow: hidden;
    isolation: isolate;
  }

  .page-header .container {
    position: relative;
    z-index: 1;
  }

  .page-header-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    opacity: 0.7;
    margin-bottom: 16px;
    text-transform: uppercase;
  }

  .page-title {
    font-size: 1.6rem;
    font-weight: 700;
  }

  .page-main {
    display: flex;
    flex-direction: column;
    min-height: calc(100vh - 72px);
  }

  .availability {
    background: white;
    flex: 1;
  }

  .availability-topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    margin-bottom: 24px;
  }

  .day-tabs {
    position: relative;
    display: flex;
    gap: 8px;
    padding: 6px;
    background: #f2f4f5;
    border-radius: 12px;
  }

  .day-tab-indicator {
    position: absolute;
    top: 6px;
    bottom: 6px;
    left: 6px;
    width: calc((100% - 20px) / 2);
    background: white;
    border-radius: 8px;
    box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
    transform: translateX(0);
    transition: transform 0.35s cubic-bezier(0.22, 1, 0.36, 1);
    z-index: 0;
  }

  .day-tabs[data-active="1"] .day-tab-indicator {
    transform: translateX(calc(100% + 8px));
  }

  .day-tab {
    position: relative;
    z-index: 1;
    flex: 1;
    min-width: 96px;
    padding: 12px 16px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--color-text-muted);
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    transition: color 0.25s;
  }

  .day-tab:hover {
    color: var(--color-navy);
  }

  .day-tab.active {
    color: var(--color-navy);
  }

  .day-viewport {
    overflow: hidden;
  }

  .day-track {
    display: flex;
    align-items: flex-start;
    gap: 24px;
    transition: transform 0.4s cubic-bezier(0.22, 1, 0.36, 1);
  }

  .day-track[data-active="1"] {
    transform: translateX(calc(-100% - 24px));
  }

  .day-panel {
    flex: 0 0 100%;
    width: 100%;
    min-width: 0;
  }

  .availability-header {
    display: flex;
    flex-direction: column;
    gap: 8px;
    margin-bottom: 32px;
    padding: 18px 24px;
    background: var(--color-turquoise-bg);
    border-radius: 16px;
  }

  .date-label {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: 0.72rem;
    color: var(--color-text-muted);
    font-weight: 600;
    letter-spacing: 0.06em;
  }

  .date-icon-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 22px;
    height: 22px;
    background: white;
    border-radius: 6px;
    flex-shrink: 0;
  }

  .date-icon {
    width: 14px;
    height: 14px;
    color: var(--color-turquoise);
    flex-shrink: 0;
  }

  .date-row {
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 16px;
  }

  .date-value {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-navy);
    white-space: nowrap;
  }

  .date-hours {
    padding: 6px 14px;
    background: white;
    border-radius: 999px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-navy);
    font-variant-numeric: tabular-nums;
    white-space: nowrap;
  }

  .date-hours:empty {
    display: none;
  }

  .last-updated {
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .status-message {
    text-align: center;
    padding: 48px 24px;
    margin-bottom: 32px;
  }

  .loading {
    font-size: 0.95rem;
    color: var(--color-text-muted);
  }

  .error {
    font-size: 0.95rem;
    color: #e05a5a;
    padding: 20px;
    background: #fff5f5;
    border-radius: 12px;
    border: 1px solid #fdd;
  }

  .closed {
    font-size: 0.95rem;
    color: var(--color-text-muted);
    padding: 20px;
    background: #f9f9f9;
    border-radius: 12px;
    border: 1px solid var(--color-border);
  }

  .slots-container {
    max-width: 900px;
    margin: 0 auto 40px;
  }

  .slots-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 10px;
  }

  .slot-card {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 16px;
    border-radius: 10px;
    border: 1px solid var(--color-border);
    background: white;
  }

  .slot-card.available {
    background: #e8f7f9;
    border-color: var(--color-turquoise);
  }

  .slot-card.unavailable {
    background: #fafafa;
    border-color: #e8e8e8;
  }

  .slot-card.past {
    background: #f8f8f8;
    border-color: #eee;
  }

  .slot-time {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .slot-card.unavailable .slot-time {
    color: #999;
  }

  .slot-card.past .slot-time {
    color: #bbb;
  }

  .slot-status {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .slot-card.available .slot-status {
    background: var(--color-turquoise);
    color: white;
  }

  .slot-card.unavailable .slot-status {
    background: #e0e0e0;
    color: #999;
  }

  .slot-card.past .slot-status {
    background: #eee;
    color: #ccc;
  }

  .hours-note {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 8px 24px;
    margin-bottom: 20px;
  }

  .hours-card {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .hours-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  .hours-card--general .hours-dot {
    background: var(--color-turquoise);
  }

  .hours-card--fever .hours-dot {
    background: #ef8f4c;
  }

  .hours-card-body {
    display: inline-flex;
    align-items: baseline;
    gap: 8px;
  }

  .hours-card-label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
  }

  .hours-card-time {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    font-variant-numeric: tabular-nums;
  }

  .availability-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-bottom: 32px;
    padding: 16px 20px;
    background: #f8f9fa;
    border-radius: 10px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .legend-badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    font-size: 0.75rem;
    font-weight: 700;
  }

  .legend-badge.available {
    background: var(--color-turquoise);
    color: white;
  }

  .legend-badge.unavailable {
    background: #e0e0e0;
    color: #999;
  }

  .legend-badge.past {
    background: #eee;
    color: #ccc;
  }

  .availability-notes {
    text-align: center;
    margin-bottom: 32px;
  }

  .availability-notes p {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 4px;
  }

  .reservation-cta {
    text-align: center;
  }

  .detail-back {
    text-align: center;
    margin-top: 48px;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
    max-width: 800px;
    margin-left: auto;
    margin-right: auto;
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    padding: 12px 32px;
    background: white;
    border: 2px solid var(--color-navy);
    border-radius: 24px;
    color: var(--color-navy);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .back-button:hover {
    background: var(--color-navy);
    color: white;
  }

  .line-button {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    padding: 16px 40px;
    background: #06c755;
    color: white;
    border-radius: 32px;
    font-size: 1rem;
    font-weight: 700;
    text-decoration: none;
    transition: all 0.2s;
    box-shadow: 0 4px 12px rgba(6, 199, 85, 0.3);
  }

  .line-button:hover {
    background: #05b04c;
    transform: translateY(-2px);
    box-shadow: 0 6px 16px rgba(6, 199, 85, 0.4);
  }

  @media (max-width: 900px) {
    .slots-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 100px 0 48px;
    }

    .page-title {
      font-size: 1.3rem;
    }

    .availability-topbar {
      flex-direction: column;
      align-items: stretch;
      gap: 12px;
    }

    .last-updated {
      text-align: right;
    }

    .availability-header {
      gap: 12px;
      padding: 16px 18px;
    }

    .date-hours {
      padding: 6px 12px;
      font-size: 0.85rem;
    }

    .date-value {
      font-size: 1.1rem;
    }

    .slots-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 8px;
    }

    .slot-card {
      padding: 12px 14px;
    }

    .slot-time {
      font-size: 0.9rem;
    }

    .slot-status {
      width: 24px;
      height: 24px;
      font-size: 0.8rem;
    }

    .availability-legend {
      flex-direction: row;
      flex-wrap: wrap;
      gap: 16px;
      justify-content: center;
    }

    .line-button {
      width: 100%;
      justify-content: center;
    }
  }
</style>

<script>
  const API_URL = 'https://koutoudai-reservation-api.kit-tamtam.workers.dev/api/procyon/availability';
  const UPDATE_INTERVAL = 5 * 60 * 1000; // 5 minutes

  interface ApiSlot {
    time: string;
    endTime: string;
    status: 'available' | 'booked';
    consultationSlotName: string;
    consultationSlotKey: string;
    medicalDepartmentKey: string;
    medicalDepartmentName: string;
  }

  interface Slot {
    time: string;
    endTime: string;
    available: boolean;
    consultationSlotName: string;
    isPast: boolean;
  }

  interface ApiDateData {
    date: string;
    dayOfWeek: number;
    isClosed: boolean;
    isHoliday: boolean;
    slots: ApiSlot[];
  }

  interface DateData {
    date: string;
    dayOfWeek: number;
    isClosed: boolean;
    isHoliday: boolean;
    slots: Slot[];
  }

  interface ApiResponse {
    dates: ApiDateData[];
  }

  function convertSlot(apiSlot: ApiSlot, dateStr: string): Slot {
    const now = new Date();
    const [hour, minute] = apiSlot.time.split(':').map(Number);
    const slotDate = new Date(dateStr);
    slotDate.setHours(hour, minute, 0, 0);

    // 5分前に受付終了
    const cutoffTime = new Date(slotDate.getTime() - 5 * 60 * 1000);

    return {
      time: apiSlot.time,
      endTime: apiSlot.endTime,
      available: apiSlot.status === 'available',
      consultationSlotName: apiSlot.consultationSlotName,
      isPast: now >= cutoffTime,
    };
  }

  function convertDateData(apiData: ApiDateData): DateData {
    return {
      date: apiData.date,
      dayOfWeek: apiData.dayOfWeek,
      isClosed: apiData.isClosed,
      isHoliday: apiData.isHoliday,
      slots: apiData.slots.map(slot => convertSlot(slot, apiData.date)),
    };
  }

  const dayNames = ['日', '月', '火', '水', '木', '金', '土'];

  function formatDate(dateStr: string): string {
    const date = new Date(dateStr);
    const month = date.getMonth() + 1;
    const day = date.getDate();
    const dayOfWeek = dayNames[date.getDay()];
    return `${month}月${day}日（${dayOfWeek}）`;
  }

  function updateLastUpdated(): void {
    const now = new Date();
    const month = String(now.getMonth() + 1).padStart(2, '0');
    const day = String(now.getDate()).padStart(2, '0');
    const hours = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const seconds = String(now.getSeconds()).padStart(2, '0');
    const element = document.getElementById('lastUpdated');
    if (element) {
      element.textContent = `${month}/${day} ${hours}:${minutes}:${seconds}`;
    }
  }

  function renderSlots(slots: Slot[], container: HTMLElement | null): void {
    if (!container) return;

    container.innerHTML = '';

    slots.forEach(slot => {
      const card = document.createElement('div');
      let statusClass: string;
      let statusText: string;

      if (slot.isPast) {
        statusClass = 'past';
        statusText = '-';
      } else if (slot.available) {
        statusClass = 'available';
        statusText = '○';
      } else {
        statusClass = 'unavailable';
        statusText = '×';
      }

      card.className = `slot-card ${statusClass}`;

      const time = document.createElement('div');
      time.className = 'slot-time';
      time.textContent = slot.time;

      const status = document.createElement('div');
      status.className = 'slot-status';
      status.textContent = statusText;

      card.appendChild(time);
      card.appendChild(status);
      container.appendChild(card);
    });
  }

  type DayState = 'open' | 'closed' | 'error' | 'loading';

  function getPanel(offsetDays: number): HTMLElement | null {
    return document.querySelector<HTMLElement>(`.day-panel[data-offset="${offsetDays}"]`);
  }

  function showMessage(panel: HTMLElement, message: string, type: 'loading' | 'error' | 'closed'): void {
    const statusMessage = panel.querySelector<HTMLElement>('.status-message');
    const slotsContainer = panel.querySelector<HTMLElement>('.slots-container');
    if (!statusMessage || !slotsContainer) return;

    statusMessage.style.display = 'block';
    statusMessage.innerHTML = `<div class="${type}">${message}</div>`;
    slotsContainer.style.display = 'none';
  }

  function hideMessage(panel: HTMLElement): void {
    const statusMessage = panel.querySelector<HTMLElement>('.status-message');
    const slotsContainer = panel.querySelector<HTMLElement>('.slots-container');
    if (!statusMessage || !slotsContainer) return;

    statusMessage.style.display = 'none';
    slotsContainer.style.display = 'block';
  }

  // 0 = 本日, 1 = 明日
  let selectedOffset = 0;
  let cachedDates: ApiDateData[] | null = null;
  const dayStates: DayState[] = ['loading', 'loading'];

  // ローカル日付を YYYY-MM-DD で取得（offsetDays 日後）
  function getDateStr(offsetDays: number): string {
    const d = new Date();
    d.setDate(d.getDate() + offsetDays);
    const year = d.getFullYear();
    const month = String(d.getMonth() + 1).padStart(2, '0');
    const day = String(d.getDate()).padStart(2, '0');
    return `${year}-${month}-${day}`;
  }

  // offsetDays に対応する日付データを、date フィールドで突き合わせて取得
  // （見つからなければ配列インデックスにフォールバック）
  function findDateData(dates: ApiDateData[], offsetDays: number): ApiDateData | null {
    const target = getDateStr(offsetDays);
    return dates.find(d => d.date === target) ?? dates[offsetDays] ?? null;
  }

  function renderDay(offsetDays: number): void {
    if (!cachedDates) return;

    const panel = getPanel(offsetDays);
    if (!panel) return;

    const dayLabel = offsetDays === 0 ? '本日' : '明日';
    const apiData = findDateData(cachedDates, offsetDays);

    // ラベル（本日/明日の診療）はサーバ描画のまま（アイコンを保持）
    const dateValue = panel.querySelector('.date-value');
    const dateHours = panel.querySelector('.date-hours');

    if (!apiData) {
      if (dateValue) dateValue.textContent = '--';
      if (dateHours) dateHours.textContent = '';
      dayStates[offsetDays] = 'error';
      showMessage(panel, `${dayLabel}のデータが見つかりませんでした`, 'error');
      return;
    }

    const dayData = convertDateData(apiData);
    if (dateValue) dateValue.textContent = formatDate(dayData.date);

    // 休診日チェック
    if (dayData.isClosed || dayData.slots.length === 0) {
      if (dateHours) dateHours.textContent = '';
      dayStates[offsetDays] = 'closed';
      showMessage(panel, `${dayLabel}は休診日です`, 'closed');
      return;
    }

    // 一般診療・発熱外来をまとめて時刻順に1つのリストで表示
    const sortByTime = (a: Slot, b: Slot) => a.time.localeCompare(b.time);
    const allSlots = [...dayData.slots].sort(sortByTime);

    // 実際の枠から診療時間帯（最初の枠〜最後の枠）を算出して表示
    if (dateHours) {
      const openTime = allSlots[0].time;
      const closeTime = allSlots[allSlots.length - 1].endTime;
      dateHours.textContent = `${openTime} - ${closeTime}`;
    }

    renderSlots(allSlots, panel.querySelector<HTMLElement>('.all-slots'));

    dayStates[offsetDays] = 'open';
    hideMessage(panel);
  }

  // 選択中の日に応じて、共有の凡例・注釈・CTA・時間帯メモの表示を切り替える
  function updateSharedChrome(offsetDays: number): void {
    const legend = document.getElementById('availabilityLegend');
    const notes = document.getElementById('availabilityNotes');
    const cta = document.getElementById('reservationCta');
    const hoursNote = document.getElementById('hoursNote');
    // 休診日は凡例・注釈・CTA・時間帯メモを非表示
    const hidden = dayStates[offsetDays] === 'closed';
    [legend, notes, cta, hoursNote].forEach(el => {
      if (el) el.style.display = hidden ? 'none' : '';
    });

    // 時間帯メモを表示中の曜日に合わせて更新（土日 14-18/18-21、平日 17-19/19-21）
    if (hoursNote && !hidden && cachedDates) {
      const apiData = findDateData(cachedDates, offsetDays);
      if (apiData) {
        const isWeekend = apiData.dayOfWeek === 0 || apiData.dayOfWeek === 6;
        const general = hoursNote.querySelector('[data-kind="general"]');
        const fever = hoursNote.querySelector('[data-kind="fever"]');
        if (general) general.textContent = isWeekend ? '14:00 - 18:00' : '17:00 - 19:00';
        if (fever) fever.textContent = isWeekend ? '18:00 - 21:00' : '19:00 - 21:00';
      }
    }
  }

  // 本日/明日の切替（スライド）— データはキャッシュ済みなので再取得不要
  function selectDay(offsetDays: number): void {
    selectedOffset = offsetDays;

    const dayTabs = document.getElementById('dayTabs');
    if (dayTabs) {
      dayTabs.setAttribute('data-active', String(offsetDays));
      dayTabs.querySelectorAll('.day-tab').forEach(t => {
        t.classList.toggle('active', Number((t as HTMLElement).dataset.offset) === offsetDays);
      });
    }

    const track = document.getElementById('dayTrack');
    if (track) {
      track.setAttribute('data-active', String(offsetDays));
    }

    updateSharedChrome(offsetDays);
  }

  async function fetchAvailability(): Promise<void> {
    try {
      const response = await fetch(API_URL);

      if (!response.ok) {
        throw new Error('予約状況の取得に失敗しました');
      }

      const data: ApiResponse = await response.json();
      cachedDates = data.dates;

      // 両日ぶんを描画しておく（切替時は即スライド表示）
      renderDay(0);
      renderDay(1);
      updateSharedChrome(selectedOffset);
      updateLastUpdated();

    } catch (error) {
      console.error('Error fetching availability:', error);
      [0, 1].forEach(offset => {
        const panel = getPanel(offset);
        if (panel) {
          dayStates[offset] = 'error';
          showMessage(
            panel,
            '予約状況の読み込みに失敗しました。<br>しばらく経ってから再度お試しください。',
            'error'
          );
        }
      });
      updateSharedChrome(selectedOffset);
    }
  }

  // タブのクリックで日付を切替
  const dayTabsEl = document.getElementById('dayTabs');
  if (dayTabsEl) {
    dayTabsEl.querySelectorAll<HTMLButtonElement>('.day-tab').forEach(tab => {
      tab.addEventListener('click', () => {
        const offset = Number(tab.dataset.offset);
        if (offset === selectedOffset) return;
        selectDay(offset);
      });
    });
  }

  // Initial fetch
  fetchAvailability();

  // Auto-refresh every 5 minutes
  setInterval(fetchAvailability, UPDATE_INTERVAL);
</script>
