---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import SubPageHeader from "../components/SubPageHeader.astro";
import Footer from "../components/Footer.astro";
import { Image } from "astro:assets";
import ecgImage from "../assets/ecg.jpeg";
import echoImage from "../assets/echo.jpeg";
import HealthIcon from "../components/HealthIcon.astro";
import InfoCard from "../components/InfoCard.astro";
---

<Layout
  title="診療内容 | 勾当台夕方内科クリニック"
  description="勾当台夕方内科クリニックの診療内容。生活習慣病の管理、急な発熱や体調不良への対応、各種検査・設備についてご案内します。"
>
  <Header />
  <main class="page-main">
    <SubPageHeader label="Medical Services" title="診療内容" />

    <section class="page-intro">
      <div class="container">
        <p class="intro-text">
          下記以外の症状もお気軽にご相談ください。<br class="pc-only" />
          必要に応じて専門医療機関へのご紹介も行います。
        </p>
        <p class="intro-note">
          ※ 健診で指摘を受けた項目の精査をご希望の方は、健診結果をお持ちください。
        </p>
      </div>
    </section>

    <section class="page-section" id="chronic">
      <div class="container">
        <h2 class="page-section-title">慢性疾患のかかりつけ</h2>
        <div class="info-box">
          <p class="info-text">
            夕方以降の時間帯で継続的に生活習慣病などの管理・治療を行います。
          </p>
        </div>
        <div class="condition-grid">
          <span class="condition-tag">高血圧</span>
          <span class="condition-tag">糖尿病</span>
          <span class="condition-tag">脂質異常症</span>
          <span class="condition-tag">高尿酸血症・痛風</span>
          <span class="condition-tag">甲状腺疾患</span>
          <span class="condition-tag">貧血</span>
          <span class="condition-tag">不眠</span>
          <span class="condition-tag">睡眠時無呼吸症候群</span>
        </div>
      </div>
    </section>

    <section class="page-section bg-turquoise" id="acute">
      <div class="container">
        <h2 class="page-section-title">夜間の急な症状にも対応</h2>
        <div class="info-box white">
          <p class="info-text">
            夕方以降の急な発熱や体調不良に対応します。
          </p>
        </div>
        <div class="condition-grid">
          <span class="condition-tag accent">発熱・感冒症状</span>
          <span class="condition-tag accent">咳・喉の痛み</span>
          <span class="condition-tag accent">腹痛・下痢</span>
          <span class="condition-tag accent">花粉症・アレルギー</span>
          <span class="condition-tag accent">頻尿・排尿時痛</span>
          <span class="condition-tag accent">倦怠感・だるさ</span>
          <span class="condition-tag accent">動悸</span>
        </div>
      </div>
    </section>

    <section class="page-section" id="exam">
      <div class="container">
        <h2 class="page-section-title">検査・設備</h2>
        <p class="section-lead">院内で実施できる検査のご案内です。</p>

        <div class="exam-grid">
          <InfoCard icon="devices/ultrasound_scanner" title="超音波検査（エコー）" variant="coral">
            <p class="info-card__description">
              腹部・腎臓・頸動脈・甲状腺などの検査を行います。
            </p>
            <Image src={echoImage} alt="超音波検査装置" width={400} class="info-card__image" />
            <span class="info-card__device">キャノンメディカルシステムズ Aplio go / LE</span>
          </InfoCard>

          <InfoCard icon="symbols/cardiogram_e" title="12誘導心電図" variant="coral">
            <p class="info-card__description">
              不整脈や狭心症など、心臓に関わる症状の評価に用います。
            </p>
            <Image src={ecgImage} alt="12誘導心電図" width={400} class="info-card__image" />
            <span class="info-card__device">日本光電 ECG-3250</span>
          </InfoCard>

          <InfoCard icon="symbols/virus" title="迅速抗原検査" variant="coral">
            <p class="info-card__description">
              院内で短時間に結果が得られる検査です。
            </p>
            <ul class="condition-list">
              <li class="condition-tag">インフルエンザA / B</li>
              <li class="condition-tag">新型コロナウイルス</li>
              <li class="condition-tag">溶連菌</li>
            </ul>
          </InfoCard>

          <InfoCard icon="devices/syringe" title="検体検査" variant="coral">
            <p class="info-card__description">
              血液検査・尿検査などは外部検査機関に委託して実施します。結果は後日お伝えいたします。
            </p>
            <ul class="condition-list">
              <li class="condition-tag">糖尿病</li>
              <li class="condition-tag">脂質異常症</li>
              <li class="condition-tag">尿酸</li>
              <li class="condition-tag">貧血</li>
              <li class="condition-tag">甲状腺</li>
              <li class="condition-tag">アレルギー</li>
              <li class="condition-tag">性感染症</li>
            </ul>
            <p class="info-card__note">※ アレルギー検査は39項目のセット検査が可能です。</p>
            <p class="info-card__note">※ 性感染症はクラミジア・淋菌・梅毒・HIVの検査が可能です。</p>
            <p class="info-card__note">※ その他、症状に応じて必要な検査を行います。</p>
          </InfoCard>
        </div>
      </div>
    </section>

    <section class="page-section back-section">
      <div class="container">
        <div class="detail-back">
          <a href="/" class="back-button">ホームに戻る</a>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-intro {
    padding: 48px 0;
    background: var(--color-turquoise-bg);
  }

  .intro-text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 2;
    text-align: center;
  }

  .intro-note {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-align: center;
    margin-top: 12px;
  }

  .pc-only {
    display: inline;
  }

  .page-section {
    padding: 80px 0;
  }

  .page-section.bg-turquoise {
    background: var(--color-turquoise-bg);
  }

  .page-section-title {
    font-size: 1.3rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 40px;
    color: var(--color-navy);
  }

  .section-lead {
    text-align: center;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    margin-bottom: 40px;
    line-height: 1.8;
  }

  .info-box {
    max-width: 720px;
    margin: 0 auto 32px;
    background: var(--color-turquoise-bg);
    border-radius: 16px;
    padding: 28px 32px;
  }

  .info-box.white {
    background: white;
  }

  .info-text {
    font-size: 0.95rem;
    color: var(--color-text);
    line-height: 2;
    text-align: center;
  }

  .condition-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 12px;
    max-width: 720px;
    margin: 0 auto;
  }

  .condition-grid.compact {
    justify-content: flex-start;
    max-width: none;
    margin: 0;
    gap: 10px;
  }

  .condition-tag {
    display: inline-block;
    padding: 8px 20px;
    background: white;
    color: var(--color-turquoise);
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 24px;
    border: 1px solid var(--color-turquoise);
  }

  .condition-tag.accent {
    color: var(--color-coral);
    border-color: var(--color-coral);
  }

  .exam-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    max-width: 960px;
    margin: 0 auto;
  }

  .back-section {
    background: white;
    padding: 40px 0 80px;
  }

  .detail-back {
    text-align: center;
    padding-top: 32px;
    border-top: 1px solid var(--color-border);
  }

  .back-button {
    display: inline-flex;
    align-items: center;
    padding: 12px 32px;
    background: white;
    border: 2px solid var(--color-navy);
    border-radius: 24px;
    color: var(--color-navy);
    font-size: 0.9rem;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .back-button:hover {
    background: var(--color-navy);
    color: white;
  }

  @media (max-width: 768px) {
    .page-intro {
      padding: 36px 0;
    }

    .intro-text {
      text-align: left;
      font-size: 0.9rem;
    }

    .pc-only {
      display: none;
    }

    .page-section {
      padding: 60px 0;
    }

    .page-section-title {
      font-size: 1.15rem;
      margin-bottom: 32px;
    }

    .section-lead {
      text-align: left;
    }

    .info-box {
      padding: 22px 18px;
    }

    .condition-grid {
      justify-content: flex-start;
    }

    .condition-tag {
      padding: 6px 16px;
      font-size: 0.85rem;
    }

    .exam-grid {
      grid-template-columns: 1fr;
      gap: 20px;
    }

  }
</style>
