---
import { Image } from "astro:assets";
import interiorImage01 from "../assets/interior01.jpeg";
import interiorImage02 from "../assets/interior02.jpeg";
import interiorImage03 from "../assets/interior03.jpeg";
import ecgImage from "../assets/ecg.jpeg";
import echoImage from "../assets/echo.jpeg";
import HealthIcon from "./HealthIcon.astro";
import InfoCard from "./InfoCard.astro";
---

<section id="about" class="section about">
  <div class="container">
    <h2 class="section-title">当院について</h2>
    <div class="about-content">
      <div class="about-text">
        <p class="about-lead">
          お仕事帰りに、<br class="sp-only" />気軽に受診できるクリニックです。
        </p>
        <p class="about-description">
          健診での指摘の精査、生活習慣病など慢性疾患の管理から急な発熱・体調不良まで、<br />
          夕方以降のかかりつけ医として、お気軽にご相談ください。
        </p>

        <div class="interior-gallery">
          <div class="interior-image-wrapper">
            <Image src={interiorImage01} alt="受付・待合室" width={560} class="interior-image" />
            <span class="interior-label">受付・待合室</span>
          </div>
          <div class="interior-image-wrapper">
            <Image src={interiorImage02} alt="診察室" width={560} class="interior-image" />
            <span class="interior-label">診察室</span>
          </div>
          <div class="interior-image-wrapper">
            <Image src={interiorImage03} alt="処置室" width={560} class="interior-image" />
            <span class="interior-label">処置室</span>
          </div>
        </div>

        <div class="about-features">
          <InfoCard icon="symbols/i_schedule_school_date_time" title="夕方〜夜間診療" variant="outlined">
            <p>17:00〜21:00まで診療。お仕事帰りにも立ち寄れます。</p>
          </InfoCard>
          <InfoCard icon="objects/calendar" title="土日・週末も診療" variant="outlined">
            <p>平日だけでなく、土曜・日曜も診療を行っています。週末や休日の通院にも対応できます。</p>
          </InfoCard>
          <InfoCard icon="symbols/geo_location" title="駅から徒歩2分" variant="outlined">
            <p>地下鉄南北線 勾当台公園駅から徒歩2分の好アクセス。</p>
          </InfoCard>
        </div>

        <div class="demographics-link-row">
          <a href="/patient-demographics" class="demographics-inline-link">当院の患者層（年代別割合）はこちら →</a>
        </div>

        <div class="medical-area">
          <h3 class="medical-heading">診療内容</h3>
          <p class="medical-note">
            下記以外の症状もお気軽にご相談ください。必要に応じて専門医療機関へのご紹介も行います。<br />
            ※ 健診で指摘を受けた項目の精査をご希望の方は、健診結果をお持ちください。
          </p>
          <div class="medical-columns">
            <InfoCard icon="symbols/clinical_fe" title="慢性疾患のかかりつけ">
              <p class="info-card__description">
                夕方以降の時間帯で継続的に生活習慣病などの管理・治療を行います。
              </p>
              <ul class="condition-list">
                <li class="condition-tag">高血圧</li>
                <li class="condition-tag">糖尿病</li>
                <li class="condition-tag">脂質異常症</li>
                <li class="condition-tag">高尿酸血症・痛風</li>
                <li class="condition-tag">甲状腺疾患</li>
                <li class="condition-tag">貧血</li>
                <li class="condition-tag">不眠</li>
                <li class="condition-tag">睡眠時無呼吸症候群</li>
              </ul>
            </InfoCard>

            <InfoCard icon="people/symptom" title="夜間の急な症状にも対応">
              <p class="info-card__description">
                夕方以降の急な発熱や体調不良に対応します。
              </p>
              <ul class="condition-list">
                <li class="condition-tag">発熱・感冒症状</li>
                <li class="condition-tag">咳・喉の痛み</li>
                <li class="condition-tag">腹痛・下痢</li>
                <li class="condition-tag">花粉症・アレルギー</li>
                <li class="condition-tag">頻尿・排尿時痛</li>
                <li class="condition-tag">倦怠感・だるさ</li>
                <li class="condition-tag">動悸</li>
              </ul>
            </InfoCard>
          </div>

          <InfoCard icon="devices/thermometer" title="発熱患者等の受入れについて" variant="outlined">
            <p>
              当院は、<strong>受診歴の有無にかかわらず</strong>、発熱その他感染症を疑わせる症状を呈する患者様の受入れを行っております。感染防止対策として、一般診療と発熱外来で<strong>診療時間帯を分ける</strong>とともに、<strong>別室の診療スペース</strong>をご用意し、必要に応じて発熱患者様の動線を他の患者様と分ける体制を整えております。
            </p>
          </InfoCard>

          <div class="articles-link-row">
            <a href="/articles" class="articles-inline-link">病気について知る →</a>
          </div>
        </div>

        <div class="exam-area">
          <h3 class="medical-heading">検査・設備</h3>
          <p class="medical-note">
            院内で実施できる検査のご案内です。
          </p>
          <div class="exam-grid">
            <InfoCard icon="devices/ultrasound_scanner" title="超音波検査（エコー）" variant="coral">
              <p class="info-card__description">
                腹部・腎臓・頸動脈・甲状腺などの検査を行います。
              </p>
              <Image src={echoImage} alt="超音波検査装置" width={400} class="info-card__image" />
              <span class="info-card__device">キャノンメディカルシステムズ Aplio go / LE</span>
            </InfoCard>

            <InfoCard icon="symbols/cardiogram_e" title="12誘導心電図" variant="coral">
              <p class="info-card__description">
                不整脈や狭心症など、心臓に関わる症状の評価に用います。
              </p>
              <Image src={ecgImage} alt="12誘導心電図" width={400} class="info-card__image" />
              <span class="info-card__device">日本光電 ECG-3250</span>
            </InfoCard>

            <InfoCard icon="symbols/virus" title="迅速抗原検査" variant="coral">
              <p class="info-card__description">
                院内で短時間に結果が得られる検査です。
              </p>
              <ul class="condition-list">
                <li class="condition-tag">インフルエンザA / B</li>
                <li class="condition-tag">新型コロナウイルス</li>
                <li class="condition-tag">溶連菌</li>
              </ul>
            </InfoCard>

            <InfoCard icon="devices/syringe" title="検体検査" variant="coral">
              <p class="info-card__description">
                血液検査・尿検査などは外部検査機関に委託して実施します。結果は後日お伝えいたします。
              </p>
              <ul class="condition-list">
                <li class="condition-tag">糖尿病</li>
                <li class="condition-tag">脂質異常症</li>
                <li class="condition-tag">尿酸</li>
                <li class="condition-tag">貧血</li>
                <li class="condition-tag">甲状腺</li>
                <li class="condition-tag">アレルギー</li>
                <li class="condition-tag">性感染症</li>
              </ul>
              <p class="info-card__note">※ アレルギー検査は39項目のセット検査が可能です。</p>
              <p class="info-card__note">※ 性感染症はクラミジア・淋菌・梅毒・HIVの検査が可能です。</p>
              <p class="info-card__note">※ その他、症状に応じて必要な検査を行います。</p>
            </InfoCard>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="section specialty-section specialty-section--turquoise">
  <div class="container">
    <div class="about-content">
      <a href="/allergen-immunotherapy" class="specialty-card">
        <div class="specialty-icon specialty-icon--turquoise">
          <HealthIcon name="symbols/cardiogram" size={28} />
        </div>
        <h4 class="specialty-title">アレルゲン免疫療法</h4>
        <p class="specialty-description">スギ花粉症・ダニアレルギーの根本的な体質改善を目指す治療を行っています。</p>
        <span class="specialty-link specialty-link--turquoise">詳しくはこちら →</span>
      </a>
    </div>
  </div>
</section>

<section class="section specialty-section specialty-section--coral">
  <div class="container">
    <div class="about-content">
      <a href="/afterpill" class="specialty-card">
        <div class="specialty-icon">
          <HealthIcon name="devices/medicine_bottle" size={28} />
        </div>
        <h4 class="specialty-title">緊急避妊薬（アフターピル）</h4>
        <p class="specialty-description">避妊に失敗した場合の緊急避妊薬を処方しています。性交後72時間以内の服用が必要です。</p>
        <span class="specialty-link">詳しくはこちら →</span>
      </a>
    </div>
  </div>
</section>

<section class="section guide-links-section">
  <div class="container">
    <div class="about-content">
      <h3 class="medical-heading">ご利用案内</h3>
      <div class="guide-accordion">
        <details class="guide-accordion-item">
          <summary class="guide-accordion-summary">
            <span class="guide-accordion-icon">
              <HealthIcon name="objects/prescription_document" size={22} />
            </span>
            <span class="guide-accordion-label">お薬の処方について</span>
            <span class="guide-accordion-chevron"></span>
          </summary>
          <div class="guide-accordion-body">
            <div class="guide-accordion-body-inner">
              <p>
                当院では原則として<strong>院外処方</strong>となります。<br />
                近隣の調剤薬局が閉まっている時間帯に限り、急性疾患に対する一部のお薬を<strong>院内でお渡し</strong>できる場合があります。
              </p>
              <p class="guide-accordion-note">※ 降圧薬・糖尿病治療薬などの慢性疾患のお薬は院外処方のみとなります。</p>
            </div>
          </div>
        </details>

        <details class="guide-accordion-item">
          <summary class="guide-accordion-summary">
            <span class="guide-accordion-icon">
              <HealthIcon name="objects/i_certificate_paper" size={22} />
            </span>
            <span class="guide-accordion-label">診断書の発行について</span>
            <span class="guide-accordion-chevron"></span>
          </summary>
          <div class="guide-accordion-body">
            <div class="guide-accordion-body-inner">
              <p>
                診断書は自費にて<strong>一律 5,500円（税込）</strong>で発行いたします。
              </p>
            </div>
          </div>
        </details>

        <details class="guide-accordion-item">
          <summary class="guide-accordion-summary">
            <span class="guide-accordion-icon">
              <HealthIcon name="objects/credit_card" size={22} />
            </span>
            <span class="guide-accordion-label">お支払いについて</span>
            <span class="guide-accordion-chevron"></span>
          </summary>
          <div class="guide-accordion-body">
            <div class="guide-accordion-body-inner">
              <p>
                現金・クレジットカード等キャッシュレス決済に対応しています。
              </p>
              <p class="guide-accordion-note">※ マイナ保険証または資格確認書をお忘れの場合は10割負担での現金払いとなります。後日お持ちいただければ差額を返金いたします。</p>
            </div>
          </div>
        </details>

        <details class="guide-accordion-item">
          <summary class="guide-accordion-summary">
            <span class="guide-accordion-icon">
              <HealthIcon name="places/hospital" size={22} />
            </span>
            <span class="guide-accordion-label">地域連携</span>
            <span class="guide-accordion-chevron"></span>
          </summary>
          <div class="guide-accordion-body">
            <div class="guide-accordion-body-inner">
              <p>
                当院は地域の基幹病院と連携し、より専門的な検査や治療が必要な場合にスムーズにご紹介できる体制を整えています。
              </p>
              <p class="guide-accordion-sub-label">連携医療機関</p>
              <ul class="guide-accordion-list">
                <li><a href="https://www.hosp.tohoku.ac.jp/" target="_blank" rel="noopener noreferrer">東北大学病院</a></li>
                <li><a href="https://nsmc.hosp.go.jp/" target="_blank" rel="noopener noreferrer">仙台医療センター</a></li>
                <li><a href="https://hospital.city.sendai.jp/" target="_blank" rel="noopener noreferrer">仙台市立病院</a></li>
                <li><a href="https://www.hosp.tohoku-mpu.ac.jp/" target="_blank" rel="noopener noreferrer">東北医科薬科大学病院</a></li>
                <li><a href="https://www.openhp.or.jp/" target="_blank" rel="noopener noreferrer">仙台オープン病院</a></li>
                <li><a href="https://www.tohokuh.johas.go.jp/" target="_blank" rel="noopener noreferrer">東北労災病院</a></li>
                <li><a href="https://tohokukosai.kkr.or.jp/" target="_blank" rel="noopener noreferrer">東北公済病院</a></li>
              </ul>
            </div>
          </div>
        </details>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: white;
  }

  .about-content {
    max-width: 960px;
    margin: 0 auto;
  }

  .about-lead {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-navy);
    text-align: center;
    margin-bottom: 24px;
    line-height: 1.9;
  }

  .about-description {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: 48px;
    line-height: 1.9;
    font-size: 0.9rem;
  }

  .demographics-link-row {
    margin-top: 24px;
    text-align: center;
  }

  .demographics-inline-link {
    font-size: 0.85rem;
    color: var(--color-turquoise);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .demographics-inline-link:hover {
    opacity: 0.7;
  }

  .articles-link-row {
    margin-top: 28px;
    text-align: center;
  }

  .articles-inline-link {
    font-size: 0.85rem;
    color: var(--color-turquoise);
    text-decoration: underline;
    text-underline-offset: 3px;
    font-weight: 600;
    transition: opacity 0.2s;
  }

  .articles-inline-link:hover {
    opacity: 0.7;
  }

  .about-features {
    display: grid;
    gap: 20px;
  }

  .medical-area {
    margin-top: 64px;
  }

  .medical-heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    text-align: center;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
  }

  .medical-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-bottom: 32px;
  }


  .medical-note {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 28px;
  }


  .specialty-section--turquoise {
    background: var(--color-turquoise-bg);
  }

  .specialty-section--coral {
    background: var(--color-coral-bg);
  }

  .specialty-card {
    display: block;
    max-width: 640px;
    margin: 0 auto;
    background: white;
    border-radius: 16px;
    padding: 32px 24px;
    text-align: center;
    text-decoration: none;
    transition: box-shadow 0.2s;
  }

  .specialty-section--turquoise .specialty-card {
    border: 1px solid var(--color-turquoise);
  }

  .specialty-section--coral .specialty-card {
    border: 1px solid var(--color-coral);
  }

  .specialty-card:hover {
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.08);
  }

  .specialty-icon {
    width: 56px;
    height: 56px;
    margin: 0 auto 16px;
    background: var(--color-coral-bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-coral);
  }

  .specialty-icon--turquoise {
    background: var(--color-turquoise-bg);
    color: var(--color-turquoise);
  }

  .specialty-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 10px;
  }

  .specialty-description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 16px;
  }

  .specialty-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-coral);
  }

  .specialty-link--turquoise {
    color: var(--color-turquoise);
  }

  .guide-links-section {
    background: white;
  }

  .guide-accordion {
    display: flex;
    flex-direction: column;
    margin-top: 24px;
    border: 1px solid var(--color-turquoise);
    border-radius: 16px;
    overflow: hidden;
  }

  .guide-accordion-item {
    border-bottom: 1px solid var(--color-turquoise);
  }

  .guide-accordion-item:last-child {
    border-bottom: none;
  }

  .guide-accordion-summary {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 20px 24px;
    cursor: pointer;
    list-style: none;
    transition: background 0.2s;
  }

  .guide-accordion-summary::-webkit-details-marker {
    display: none;
  }

  @media (hover: hover) {
    .guide-accordion-summary:hover {
      background: var(--color-turquoise-bg);
    }
  }

  .guide-accordion-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: var(--color-turquoise-bg);
    border-radius: 10px;
    color: var(--color-turquoise);
  }


  .guide-accordion-label {
    flex: 1;
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.4;
  }

  .guide-accordion-chevron {
    flex-shrink: 0;
    width: 8px;
    height: 8px;
    border-right: 2px solid var(--color-text-muted);
    border-bottom: 2px solid var(--color-text-muted);
    transform: rotate(45deg);
    transition: transform 0.2s;
  }

  .guide-accordion-item[open] .guide-accordion-chevron {
    transform: rotate(-135deg);
  }

  .guide-accordion-body {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.25s ease;
    padding: 0 24px 0 76px;
  }

  .guide-accordion-item[open] .guide-accordion-body {
    grid-template-rows: 1fr;
  }

  .guide-accordion-body-inner {
    overflow: hidden;
  }

  .guide-accordion-item[open] .guide-accordion-body-inner {
    padding-bottom: 24px;
  }

  .guide-accordion-body p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }

  .guide-accordion-body p strong {
    color: var(--color-navy);
    font-weight: 700;
  }

  .guide-accordion-note {
    font-size: 0.78rem !important;
    margin-top: 10px;
  }

  .guide-accordion-sub-label {
    font-size: 0.82rem !important;
    font-weight: 500;
    margin-top: 16px;
    margin-bottom: 8px;
  }

  .guide-accordion-list {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding-left: 1.2em;
    list-style: disc;
  }

  .guide-accordion-list li {
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .guide-accordion-list a {
    color: var(--color-navy);
    text-decoration: none;
    transition: color 0.2s;
  }

  .guide-accordion-list a:hover {
    text-decoration: underline;
  }

  .interior-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin-bottom: 48px;
  }

  .interior-image-wrapper {
    border-radius: 16px;
    overflow: hidden;
    position: relative;
  }

  .interior-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .interior-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 10px 12px;
    background: linear-gradient(transparent, rgba(30, 58, 95, 0.7));
    color: white;
    font-size: 0.78rem;
    font-weight: 500;
    text-align: center;
    letter-spacing: 0.06em;
  }


  .exam-area {
    margin-top: 64px;
  }

  .exam-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }




  .sp-only {
    display: none;
  }

  @media (max-width: 768px) {
    .sp-only {
      display: inline;
    }

    .about-lead {
      font-size: 1rem;
    }

    .about-description {
      font-size: 0.9rem;
      text-align: left;
    }

    .medical-area {
      margin-top: 40px;
    }

    .medical-heading {
      font-size: 1rem;
      margin-bottom: 20px;
    }

    .medical-columns {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .medical-note {
      text-align: left;
