<style>
  .insurance-banner {
    background: #fdf2e6;
    border-bottom: 2px solid #e8a04c;
    padding: 16px 0;
  }

  .insurance-banner-inner {
    display: flex;
    align-items: flex-start;
    gap: 12px;
  }

  .insurance-banner-body {
    flex: 1;
  }

  .insurance-banner-title {
    font-size: 0.92rem;
    font-weight: 700;
    color: #b0472f;
    line-height: 1.6;
    margin-bottom: 4px;
  }

  .insurance-banner-text {
    font-size: 0.82rem;
    color: #444;
    line-height: 1.8;
  }

  .insurance-banner-text strong {
    color: #c05040;
  }

  @media (max-width: 768px) {
    .insurance-banner-title {
      font-size: 0.88rem;
    }

    .insurance-banner-text {
      font-size: 0.78rem;
