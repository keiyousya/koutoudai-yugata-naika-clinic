---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import LineCta from "../components/LineCta.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="花粉症の診療・処方 | 勾当台夕方内科クリニック | 仙台市"
  description="仙台市で花粉症の薬をもらうなら。勾当台夕方内科クリニックでは夕方17時から夜21時まで花粉症の診療・処方に対応。抗ヒスタミン薬、点鼻薬、目薬など。土日も診療。仕事帰りに処方を受けられます。"
>
  <Header />
  <main class="page-main">
    <PageHero
      label="Hay Fever Treatment"
      title="花粉症の診療・処方"
      description="「花粉症の薬がほしいけど、日中は病院に行けない」——<br />当院では<strong>夕方17時から夜21時まで</strong>花粉症の診療・処方を行っています。<br />仕事帰りに立ち寄って、お薬を受け取ることができます。"
    />

    <section class="page-section">
      <div class="container">
        <h2 class="page-section-title">処方できるお薬</h2>
        <p class="page-section-lead">
          症状に合わせて、適切なお薬を処方いたします。
        </p>

        <div class="medicine-grid">
          <div class="medicine-card">
            <h3 class="medicine-card-title">抗ヒスタミン薬（内服）</h3>
            <p class="medicine-card-description">
              くしゃみ・鼻水・鼻づまり・目のかゆみなど、花粉症の主な症状を抑えます。眠くなりにくいタイプもあります。
            </p>
          </div>
          <div class="medicine-card">
            <h3 class="medicine-card-title">点鼻薬</h3>
            <p class="medicine-card-description">
              鼻づまりがひどい方に。ステロイド点鼻薬など、局所に作用して症状を和らげます。
            </p>
          </div>
          <div class="medicine-card">
            <h3 class="medicine-card-title">点眼薬（目薬）</h3>
            <p class="medicine-card-description">
              目のかゆみ・充血がつらい方に。抗アレルギー点眼薬を処方します。
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section bg-warm">
      <div class="container">
        <h2 class="page-section-title">花粉症の主な症状</h2>
        <div class="symptom-grid">
          <div class="symptom-item">
            <span class="symptom-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </span>
            <span>くしゃみ</span>
          </div>
          <div class="symptom-item">
            <span class="symptom-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </span>
            <span>鼻水</span>
          </div>
          <div class="symptom-item">
            <span class="symptom-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </span>
            <span>鼻づまり</span>
          </div>
          <div class="symptom-item">
            <span class="symptom-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </span>
            <span>目のかゆみ</span>
          </div>
          <div class="symptom-item">
            <span class="symptom-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </span>
            <span>目の充血</span>
          </div>
          <div class="symptom-item">
            <span class="symptom-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
              </svg>
            </span>
            <span>喉のかゆみ</span>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="container">
        <h2 class="page-section-title">仙台の花粉シーズン</h2>
        <div class="season-box">
          <div class="season-item">
            <h3 class="season-title">スギ花粉</h3>
            <p class="season-period">2月〜4月</p>
          </div>
          <div class="season-item">
            <h3 class="season-title">ヒノキ花粉</h3>
            <p class="season-period">4月〜5月</p>
          </div>
          <div class="season-item">
            <h3 class="season-title">イネ科花粉</h3>
            <p class="season-period">5月〜7月</p>
          </div>
          <div class="season-item">
            <h3 class="season-title">ブタクサ花粉</h3>
            <p class="season-period">8月〜10月</p>
          </div>
        </div>
        <p class="season-note">
          ※ 症状が出始める前から薬を飲み始めると、シーズン中の症状を軽減できます。
        </p>
      </div>
    </section>

    <section class="page-section bg-blue">
      <div class="container">
        <h2 class="page-section-title">当院の特徴</h2>
        <ul class="feature-list">
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </span>
            <div>
              <strong>夕方17時〜夜21時まで診療</strong>
              <p>仕事帰りに立ち寄って処方を受けられます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <div>
              <strong>土日も診療</strong>
              <p>平日に時間が取れない方も週末に受診できます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <div>
              <strong>勾当台公園駅から徒歩2分</strong>
              <p>地下鉄でアクセス便利。仕事帰りに立ち寄りやすい立地です。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
                <polyline points="14 2 14 8 20 8"/>
                <line x1="16" y1="13" x2="8" y2="13"/>
                <line x1="16" y1="17" x2="8" y2="17"/>
              </svg>
            </span>
            <div>
              <strong>処方箋はその場で発行</strong>
              <p>お近くの調剤薬局でお薬を受け取れます。</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <section class="page-cta">
      <div class="container">
        <LineCta lines={[
          "花粉症でお困りの方は、",
          "お気軽にご来院ください。",
          "症状に合わせて適切なお薬を処方いたします。"
        ]} />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-section {
    padding: 80px 0;
  }

  .page-section.bg-warm {
    background: var(--color-bg-warm);
  }

  .page-section.bg-blue {
    background: var(--color-bg-blue);
  }

  .page-section-title {
    font-size: 1.3rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 20px;
    color: var(--color-navy);
  }

  .page-section-lead {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 40px;
  }

  .medicine-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .medicine-card {
    background: var(--color-bg-blue);
    border-radius: 4px;
    padding: 28px;
    border-top: 3px solid var(--color-navy);
  }

  .medicine-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
  }

  .medicine-card-description {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .symptom-grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 16px;
    max-width: 600px;
    margin: 0 auto;
  }

  .symptom-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 12px 20px;
    background: white;
    border-radius: 4px;
    font-size: 0.95rem;
    color: var(--color-text-secondary);
  }

  .symptom-icon {
    color: var(--color-navy-medium);
    width: 20px;
    height: 20px;
  }

  .symptom-icon svg {
    width: 16px;
    height: 16px;
  }

  .season-box {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
    max-width: 800px;
    margin: 0 auto 24px;
  }

  .season-item {
    background: var(--color-bg-warm);
    border-radius: 4px;
    padding: 24px;
    text-align: center;
  }

  .season-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .season-period {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .season-note {
    text-align: center;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .feature-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 24px;
    background: white;
    border-radius: 4px;
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-navy-medium);
    width: 32px;
    height: 32px;
  }

  .feature-item strong {
    display: block;
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .feature-item p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .page-cta {
    background: white;
    padding: 64px 0;
    text-align: center;
  }

  .page-cta-text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 2;
    margin-bottom: 28px;
  }

  .page-cta-button {
    display: inline-block;
    background: var(--color-navy);
    color: white;
    padding: 16px 48px;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .page-cta-button:hover {
    background: var(--color-navy-light);
  }

  .page-cta-button.line-button {
    background: #06C755;
  }

  .page-cta-button.line-button:hover {
    background: #05b34c;
  }

  .page-cta-note {
    margin-top: 14px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .page-section {
      padding: 60px 0;
    }

    .medicine-grid {
      grid-template-columns: 1fr;
    }

    .season-box {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>
