---
const schedule = [
  { day: "月", open: false },
  { day: "火", open: false },
  { day: "水", open: true },
  { day: "木", open: true },
  { day: "金", open: true },
  { day: "土", open: true },
  { day: "日", open: true },
];
---

<section id="hours" class="section hours">
  <div class="container">
    <h2 class="section-title">診療時間</h2>
    <div class="hours-content">
      <div class="hours-main">
        <div class="hours-row">
          <span class="time-label">一般診療</span>
          <span class="time-value">17:00 - 19:00</span>
        </div>
        <div class="hours-row">
          <span class="time-label">発熱外来</span>
          <span class="time-value">19:00 - 21:00</span>
        </div>
      </div>

      <div class="hours-last-reception">
        <span class="last-reception-label">最終受付</span>
        <span class="last-reception-time">20:30</span>
        <span class="last-reception-note">（電話・ウェブ予約の当日最終）</span>
      </div>

      <div class="schedule-table">
        <div class="schedule-header">
          <span>診療日カレンダー</span>
        </div>
        <div class="schedule-grid">
          {
            schedule.map((item) => (
              <div class={`schedule-cell ${item.open ? "open" : "closed"}`}>
                <span class="day">{item.day}</span>
                <span class="status">{item.open ? "○" : "休"}</span>
              </div>
            ))
          }
        </div>
      </div>

      <div class="hours-info">
        <div class="info-item">
          <span class="info-icon open">○</span>
          <span>診療日（水〜日）</span>
        </div>
        <div class="info-item">
          <span class="info-icon closed">休</span>
          <span>休診日（月・火・祝）</span>
        </div>
      </div>

      <div class="hours-notice">
        <p>
          ※急な休診の場合は、当院ウェブサイトにてお知らせいたします。
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hours {
    background: var(--color-bg-warm);
  }

  .hours-content {
    max-width: 960px;
    margin: 0 auto;
  }

  .hours-main {
    text-align: center;
    margin-bottom: 36px;
    padding: 32px;
    background: white;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .hours-row {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 20px;
  }

  .hours-row + .hours-row {
    margin-top: 16px;
    padding-top: 16px;
    border-top: 1px solid var(--color-border);
  }

  .time-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
    min-width: 5em;
    text-align: right;
  }

  .time-value {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-navy);
    letter-spacing: 0.03em;
  }

  .hours-last-reception {
    text-align: center;
    margin-bottom: 36px;
    padding: 18px 32px;
    background: var(--color-bg-blue);
    border-radius: 4px;
    border: 1px solid var(--color-border);
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 12px;
    flex-wrap: wrap;
  }

  .last-reception-label {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .last-reception-time {
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-navy);
    letter-spacing: 0.03em;
  }

  .last-reception-note {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .hours-note {
    margin-top: 12px;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .schedule-table {
    background: white;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    margin-bottom: 24px;
  }

  .schedule-header {
    background: var(--color-navy);
    color: white;
    padding: 14px;
    text-align: center;
    font-weight: 500;
    font-size: 0.9rem;
    letter-spacing: 0.03em;
  }

  .schedule-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
  }

  .schedule-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 24px 10px;
    border-right: 1px solid var(--color-border);
  }

  .schedule-cell:last-child {
    border-right: none;
  }

  .schedule-cell .day {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-bottom: 8px;
  }

  .schedule-cell .status {
    font-size: 1.1rem;
    font-weight: 700;
  }

  .schedule-cell.open .status {
    color: var(--color-navy);
  }

  .schedule-cell.closed .status {
    color: #888;
  }

  .schedule-cell.closed {
    background: #f9f9f9;
  }

  .hours-info {
    display: flex;
    justify-content: center;
    gap: 36px;
    margin-bottom: 28px;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .info-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    font-size: 0.9rem;
    font-weight: 700;
  }

  .info-icon.open {
    background: var(--color-bg-blue);
    color: var(--color-navy);
  }

  .info-icon.closed {
    background: #f5f5f5;
    color: #666;
  }

  .hours-notice {
    text-align: center;
    padding: 20px;
    background: white;
    border-radius: 4px;
    border: 1px solid var(--color-border);
  }

  .hours-notice p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 768px) {
    .time-value {
      font-size: 1.4rem;
    }

    .schedule-cell {
      padding: 16px 4px;
    }

    .schedule-cell .day {
      font-size: 0.9rem;
    }

    .schedule-cell .status {
      font-size: 1rem;
    }

    .hours-info {
      flex-direction: column;
      align-items: center;
      gap: 12px;
      font-size: 0.9rem;
    }

    .hours-notice p {
      font-size: 0.9rem;
      text-align: left;
    }
  }
</style>
