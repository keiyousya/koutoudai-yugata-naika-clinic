---
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="container">
    <div class="footer-content">
      <div class="footer-info">
        <h3 class="footer-logo">勾当台夕方内科クリニック</h3>
        <address class="footer-address">
          〒980-0803<br />
          宮城県仙台市青葉区国分町3丁目8-1<br />
          勾当台ビル 4階
        </address>
        <p class="footer-tel">
          <a href="tel:022-393-8689">022-393-8689</a>
        </p>
        <p class="footer-pre-open-note">※ 4月8日の開院までは、お電話に出られない場合がございます</p>
      </div>

      <div class="footer-hours">
        <h4>診療時間</h4>
        <p>一般診療 17:00 - 19:00</p>
        <p>発熱外来 19:00 - 21:00</p>
        <p class="footer-days">水・木・金・土・日</p>
        <p class="footer-closed">月・火 休診</p>
      </div>

      <div class="footer-nav">
        <h4>メニュー</h4>
        <ul>
          <li><a href="/#about">当院について</a></li>
          <li><a href="/#hours">診療時間</a></li>
          <li><a href="/#reservation">ご予約</a></li>
          <li><a href="/#access">アクセス</a></li>
          <li><a href="/#doctor">院長紹介</a></li>
          <li><a href="/#recruit">採用情報</a></li>
        </ul>
      </div>
    </div>

    <div class="footer-bottom">
      <p class="footer-legal">
        <a href="/tokushoho">特定商取引法に基づく表記</a>
      </p>
      <p class="copyright">
        &copy; {currentYear} 勾当台夕方内科クリニック All Rights Reserved.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-navy);
    color: white;
    padding: 68px 0 28px;
  }

  .footer-content {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr;
    gap: 56px;
    margin-bottom: 56px;
  }

  .footer-logo {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 18px;
    letter-spacing: 0.04em;
  }

  .footer-address {
    font-style: normal;
    font-size: 0.9rem;
    line-height: 1.8;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 14px;
  }

  .footer-tel a {
    font-size: 1.1rem;
    font-weight: 500;
    color: white;
    transition: opacity 0.2s;
  }

  .footer-tel a:hover {
    opacity: 0.8;
  }

  .footer-pre-open-note {
    font-size: 0.75rem;
    color: rgba(255, 200, 180, 0.9);
    margin-top: 6px;
  }

  .footer-hours h4,
  .footer-nav h4 {
    font-size: 0.9rem;
    font-weight: 500;
    margin-bottom: 16px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    letter-spacing: 0.03em;
  }

  .footer-hours p {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.8);
    margin-bottom: 4px;
  }

  .footer-days {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .footer-closed {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
  }

  .footer-nav ul {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .footer-nav a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.2s;
  }

  .footer-nav a:hover {
    color: white;
  }

  .footer-bottom {
    padding-top: 28px;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    text-align: center;
  }

  .footer-legal {
    margin-bottom: 16px;
  }

  .footer-legal a {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.6);
    transition: color 0.2s;
  }

  .footer-legal a:hover {
    color: white;
  }

  .copyright {
    font-size: 0.9rem;
    color: rgba(255, 255, 255, 0.65);
  }

  @media (max-width: 768px) {
    .footer {
      padding: 52px 0 24px;
    }

    .footer-content {
      grid-template-columns: 1fr;
      gap: 36px;
      text-align: center;
    }

    .footer-hours h4,
    .footer-nav h4 {
      border-bottom: none;
      padding-bottom: 0;
    }

    .footer-nav ul {
      gap: 8px;
    }
  }
</style>
