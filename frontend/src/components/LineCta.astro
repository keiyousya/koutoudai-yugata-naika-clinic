---
import LineButton from "./LineButton.astro";

interface Props {
  lines?: string[];
  showIntro?: boolean;
}

const { lines = [], showIntro = false } = Astro.props;
---

<div class="line-cta">
  {showIntro && (
    <p class="line-cta-intro">
      当院ではLINEからのご予約をお願いしております。友だち追加後、トーク画面よりご予約ください。
    </p>
  )}
  {lines.length > 0 && (
    <p class="line-cta-text">
      {lines.map((line) => (
        <span class="cta-line">{line}</span>
      ))}
    </p>
  )}
  <LineButton />
</div>

<style>
  .line-cta {
    text-align: center;
  }

  .line-cta-intro {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
  }

  .line-cta-text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 2;
    margin-bottom: 28px;
  }

  .cta-line {
    display: inline;
  }

  @media (max-width: 768px) {
    .cta-line {
      display: block;
    }
  }
</style>
