---
const newsItems = [
  {
    date: "2026.04.29",
    content: "5月3日（日）・5月6日（水）は祝日ですが、通常通り診療いたします。",
    isImportant: true,
  },
  {
    date: "2026.04.12",
    content: "5月9日（土）は臨時休診となります。",
    isImportant: true,
  },
];
---

<section id="news" class="section news">
  <div class="container">
    <h2 class="section-title">お知らせ</h2>
    <div class="news-content">
      <ul class="news-list">
        {newsItems.map((item) => (
          <li class={`news-item ${item.isImportant ? "important" : ""}`}>
            <span class="news-date">{item.date}</span>
            <span class="news-text">{item.content}</span>
          </li>
        ))}
      </ul>
      <div class="news-link">
        <a href="#hours">診療時間・カレンダーを見る</a>
      </div>
    </div>
  </div>
</section>

<style>
  .news {
    background: white;
    padding-top: 48px;
    padding-bottom: 48px;
  }

  .news-content {
    max-width: 720px;
    margin: 0 auto;
  }

  .news-list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .news-item {
    display: flex;
    align-items: baseline;
    gap: 20px;
    padding: 18px 24px;
    background: var(--color-turquoise-bg);
    border-radius: 16px;
  }

  .news-item.important {
    background: var(--color-turquoise-bg);
  }

  .news-date {
    flex-shrink: 0;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    font-weight: 500;
  }

  .news-text {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.7;
  }

  .news-item.important .news-text {
    color: var(--color-navy);
    font-weight: 500;
  }

  .news-link {
    text-align: center;
    margin-top: 20px;
  }

  .news-link a {
    color: var(--color-turquoise);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .news-link a:hover {
    opacity: 0.8;
  }

  @media (max-width: 768px) {
    .news {
      padding-top: 36px;
      padding-bottom: 36px;
    }

    .news-item {
      flex-direction: column;
      gap: 6px;
      padding: 14px 16px;
    }

    .news-date {
      font-size: 0.8rem;
    }

    .news-text {
      font-size: 0.9rem;
    }
  }
</style>
