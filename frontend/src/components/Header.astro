---
import logoSvg from "../assets/logo.svg?raw";

const navItems = [
  { href: "/#about", label: "当院について" },
  { href: "/#hours", label: "診療時間" },
  { href: "/#reservation", label: "ご予約" },
  { href: "/#access", label: "アクセス" },
  { href: "/#doctor", label: "院長紹介" },
  // { href: "/#recruit", label: "採用情報" },
];
---

<header class="header">
  <div class="header-inner container">
    <a href="/" class="logo">
      <div class="logo-img" set:html={logoSvg} />
      <span class="logo-main">勾当台夕方内科クリニック</span>
    </a>
    <nav class="nav">
      <ul class="nav-list">
        {
          navItems.map((item) => (
            <li>
              <a href={item.href} class="nav-link">
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
    <div class="header-actions">
      <a href="tel:022-393-8689" class="header-icon-btn" aria-label="電話する">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
        </svg>
      </a>
      <a href="/#reservation" class="header-icon-btn" aria-label="予約する">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
        </svg>
      </a>
      <button class="menu-toggle" aria-label="メニューを開く">
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
        <span class="menu-bar"></span>
      </button>
    </div>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    z-index: 1000;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    padding: 0 132px 0 12px;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .logo-img {
    height: 44px;
    width: 44px;
    flex-shrink: 0;
  }

  .logo-img :global(svg) {
    width: 100%;
    height: 100%;
  }

  .logo-main {
    font-family: var(--font-brand);
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--color-navy);
    letter-spacing: -0.02em;
  }

  .nav {
    margin-left: auto;
  }

  .nav-list {
    display: flex;
    gap: 28px;
  }

  .nav-link {
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    transition: color 0.2s;
    position: relative;
    letter-spacing: 0.02em;
  }

  .nav-link:hover {
    color: var(--color-navy);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 4px;
  }

  .header-icon-btn {
    display: none;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 60px;
    color: var(--color-navy);
    transition: opacity 0.2s;
    border-left: 1px solid #e5e5e5;
  }

  .header-icon-btn:hover {
    opacity: 0.6;
  }

  .menu-toggle {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 5px;
    width: 52px;
    height: 60px;
    background: none;
    border: none;
    border-left: 1px solid #e5e5e5;
    cursor: pointer;
  }

  .menu-bar {
    width: 24px;
    height: 2px;
    background: var(--color-navy);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .menu-toggle.active .menu-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .menu-toggle.active .menu-bar:nth-child(2) {
    opacity: 0;
  }

  .menu-toggle.active .menu-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  @media (max-width: 960px) {
    .logo {
      gap: 6px;
    }

    .logo-img {
      height: 28px;
      width: 28px;
    }

    .logo-main {
      font-size: 0.75rem;
    }
  }

  @media (max-width: 854px) {
    .header-inner {
      padding: 0 0 0 12px;
    }

    .header-actions {
      gap: 0;
    }

    .nav {
      position: absolute;
      top: 60px;
      left: 0;
      right: 0;
      background: white;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
      transform: translateY(-20px);
      opacity: 0;
      visibility: hidden;
      transition: transform 0.3s ease, opacity 0.3s ease, visibility 0.3s;
    }

    .nav.active {
      transform: translateY(0);
      opacity: 1;
      visibility: visible;
    }

    .nav-list {
      flex-direction: column;
      gap: 0;
      padding: 16px 0;
    }

    .nav-link {
      display: block;
      padding: 16px 24px;
    }

    .nav-link::after {
      display: none;
    }

    .header-icon-btn {
      display: flex;
    }

    .menu-toggle {
      display: flex;
    }
  }
</style>

<script>
  const menuToggle = document.querySelector(".menu-toggle");
  const nav = document.querySelector(".nav");

  menuToggle?.addEventListener("click", () => {
    menuToggle.classList.toggle("active");
    nav?.classList.toggle("active");
  });

  document.querySelectorAll(".nav-link").forEach((link) => {
    link.addEventListener("click", () => {
      menuToggle?.classList.remove("active");
      nav?.classList.remove("active");
    });
  });
</script>
