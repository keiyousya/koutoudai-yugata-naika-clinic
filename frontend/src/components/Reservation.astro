---
// LINE予約システムの設定
// リリース時に lineAddFriendUrl を設定し、comingSoon を false にする
const config = {
  comingSoon: false,
  lineAddFriendUrl: "https://lin.ee/o8VUXOX",
};
---

<section id="reservation" class="section reservation">
  <div class="container">
    <h2 class="section-title">ご予約</h2>
    <div class="reservation-content">
      {config.comingSoon ? (
        <p class="reservation-notice">
          開院日が近づきましたら、こちらにご案内を掲載いたします。
        </p>
      ) : (
        <div class="line-block">
          <p class="reservation-notice">
            LINE公式アカウントを友だち追加後、トーク画面よりご予約ください。
          </p>
          <a href={config.lineAddFriendUrl} target="_blank" rel="noopener noreferrer">
            <img src="https://scdn.line-apps.com/n/line_add_friends/btn/ja.png" alt="友だち追加" style="height:48px; width:auto; border:0;" />
          </a>
        </div>
      )}

    </div>
  </div>
</section>

<style>
  .reservation {
    background: white;
  }

  .reservation-content {
    max-width: 640px;
    margin: 0 auto;
    text-align: center;
  }

  .reservation-notice {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.9;
    margin-bottom: 28px;
  }

  .line-block {
    margin-bottom: 0;
  }

  .line-btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 14px 36px;
    background: #06C755;
    color: white;
    font-size: 0.9rem;
    font-weight: 600;
    border-radius: 4px;
    letter-spacing: 0.03em;
    transition: opacity 0.2s;
    margin-bottom: 28px;
  }

  .line-btn:hover {
    opacity: 0.85;
  }

</style>
