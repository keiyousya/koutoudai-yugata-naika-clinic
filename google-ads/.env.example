# Google Ads API 認証情報（.env にコピーして埋める。.env はコミットしない）
# 取得手順は README.md を参照

# Google Ads API の開発者トークン（API Center で発行）
GOOGLE_ADS_DEVELOPER_TOKEN=

# OAuth2 クライアント（Google Cloud Console > 認証情報）
GOOGLE_ADS_CLIENT_ID=
GOOGLE_ADS_CLIENT_SECRET=

# 上記クライアントで生成したリフレッシュトークン
GOOGLE_ADS_REFRESH_TOKEN=

# MCC（管理者）アカウントから操作する場合のログインアカウントID（ハイフンなし10桁）
# 単一アカウント運用なら操作対象と同じIDでよい
GOOGLE_ADS_LOGIN_CUSTOMER_ID=

# 操作対象のアカウントID（ハイフンなし10桁）。--customer-id 未指定時の既定値
GOOGLE_ADS_CUSTOMER_ID=

# google-ads ライブラリ必須。proto-plus メッセージを使う（True 固定でよい）
GOOGLE_ADS_USE_PROTO_PLUS=True
