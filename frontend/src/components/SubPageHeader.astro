---
interface Props {
  label: string;
  title: string;
}

const { label, title } = Astro.props;
---

<div class="sub-page-header">
  <div class="container">
    <p class="sub-page-header-label">{label}</p>
    <h1 class="sub-page-header-title">{title}</h1>
  </div>
</div>

<style>
  .sub-page-header {
    padding: 72px 0 0;
    text-align: center;
    background: white;
  }

  .sub-page-header::after {
    content: "";
    display: block;
    width: 40px;
    height: 2px;
    margin: 10px auto 30px;
    border-radius: 1px;
    background: var(--color-turquoise);
  }

  .sub-page-header-label {
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-turquoise);
    margin-bottom: 4px;
  }

  .sub-page-header-title {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--color-navy);
    margin: 0;
    line-height: 1.5;
  }

  .sub-page-header + :global(.section),
  .sub-page-header + :global(.page-section),
  .sub-page-header + :global(section) {
    padding-top: 20px;
  }

  @media (max-width: 768px) {
    .sub-page-header {
      padding: 64px 0 0;
    }

    .sub-page-header-title {
      font-size: 1.15rem;
    }
  }
</style>
