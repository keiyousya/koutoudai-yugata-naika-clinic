---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import PageHero from "../components/PageHero.astro";
import LineCta from "../components/LineCta.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="発熱・風邪症状の診療 | 勾当台夕方内科クリニック | 仙台市"
  description="仙台市で夜間に発熱したら。勾当台夕方内科クリニックでは夕方17時から夜21時まで発熱外来を実施。インフルエンザ・コロナの迅速検査、風邪・咳・喉の痛みに対応。土日も診療。"
>
  <Header />
  <main class="page-main">
    <PageHero
      label="Fever / Cold Symptoms"
      title="発熱・風邪症状の診療"
      description="仕事中に熱が出た、夕方から体調が悪くなった——<br />当院では<strong>夕方17時から夜21時まで</strong>発熱・風邪症状の診療を行っています。<br />インフルエンザ・新型コロナの迅速検査にも対応しています。"
    />

    <section class="page-section">
      <div class="container">
        <h2 class="page-section-title">対応できる症状</h2>
        <div class="symptom-grid">
          <div class="symptom-card">
            <h3 class="symptom-card-title">発熱</h3>
            <p class="symptom-card-description">
              急な発熱、微熱が続く、熱が下がらないなど
            </p>
          </div>
          <div class="symptom-card">
            <h3 class="symptom-card-title">咳・痰</h3>
            <p class="symptom-card-description">
              咳が止まらない、痰が絡む、咳で眠れないなど
            </p>
          </div>
          <div class="symptom-card">
            <h3 class="symptom-card-title">喉の痛み</h3>
            <p class="symptom-card-description">
              喉が痛い、飲み込むと痛い、声が出にくいなど
            </p>
          </div>
          <div class="symptom-card">
            <h3 class="symptom-card-title">鼻水・鼻づまり</h3>
            <p class="symptom-card-description">
              鼻水が止まらない、鼻が詰まる、くしゃみが出るなど
            </p>
          </div>
          <div class="symptom-card">
            <h3 class="symptom-card-title">頭痛・倦怠感</h3>
            <p class="symptom-card-description">
              頭が痛い、体がだるい、節々が痛いなど
            </p>
          </div>
          <div class="symptom-card">
            <h3 class="symptom-card-title">腹痛・下痢・嘔吐</h3>
            <p class="symptom-card-description">
              お腹が痛い、下痢が続く、吐き気があるなど
            </p>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section bg-warm">
      <div class="container">
        <h2 class="page-section-title">迅速検査</h2>
        <p class="page-section-lead">
          院内で短時間に結果が得られる検査を行っています。
        </p>
        <div class="test-grid">
          <div class="test-card">
            <h3 class="test-card-title">インフルエンザ</h3>
            <p class="test-card-description">A型・B型の判定が可能</p>
          </div>
          <div class="test-card">
            <h3 class="test-card-title">新型コロナウイルス</h3>
            <p class="test-card-description">抗原検査による迅速判定</p>
          </div>
          <div class="test-card">
            <h3 class="test-card-title">溶連菌</h3>
            <p class="test-card-description">喉の痛みの原因を特定</p>
          </div>
        </div>
      </div>
    </section>

    <section class="page-section">
      <div class="container">
        <h2 class="page-section-title">診療の特徴</h2>
        <ul class="feature-list">
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </span>
            <div>
              <strong>夕方17時〜夜21時まで診療</strong>
              <p>日中は仕事で受診できない方も、仕事帰りに立ち寄れます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <div>
              <strong>土日も診療</strong>
              <p>週末に体調を崩しても受診できます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/>
              </svg>
            </span>
            <div>
              <strong>予約なしでも受診可能</strong>
              <p>急な発熱でも、予約なしで直接ご来院いただけます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M3 3h18v18H3zM21 9H3M9 21V9"/>
              </svg>
            </span>
            <div>
              <strong>一部のお薬は院内でお渡し可能</strong>
              <p>近隣の薬局が閉まっている時間帯は、一部のお薬を院内でお渡しできます。</p>
            </div>
          </li>
        </ul>
      </div>
    </section>

    <section class="page-section bg-blue">
      <div class="container">
        <h2 class="page-section-title">こんな時はご相談ください</h2>
        <ul class="case-list">
          <li>仕事中に熱が出て、夕方からしか病院に行けない</li>
          <li>インフルエンザかどうか検査してほしい</li>
          <li>コロナの検査を受けたい</li>
          <li>咳が止まらず、薬がほしい</li>
          <li>週末に体調を崩したが、月曜まで待てない</li>
        </ul>
      </div>
    </section>

    <section class="page-cta">
      <div class="container">
        <LineCta lines={[
          "発熱や風邪症状でお困りの方は、",
          "お気軽にご来院ください。",
          "夕方以降・土日も診療しています。"
        ]} />
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  .page-section {
    padding: 80px 0;
  }

  .page-section.bg-warm {
    background: var(--color-bg-warm);
  }

  .page-section.bg-blue {
    background: var(--color-bg-blue);
  }

  .page-section-title {
    font-size: 1.3rem;
    font-weight: 700;
    text-align: center;
    margin-bottom: 20px;
    color: var(--color-navy);
  }

  .page-section-lead {
    text-align: center;
    color: var(--color-text-muted);
    font-size: 0.9rem;
    margin-bottom: 40px;
  }

  .symptom-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .symptom-card {
    background: var(--color-bg-blue);
    border-radius: 4px;
    padding: 24px;
    text-align: center;
  }

  .symptom-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 10px;
  }

  .symptom-card-description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  .test-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    max-width: 800px;
    margin: 0 auto;
  }

  .test-card {
    background: white;
    border-radius: 4px;
    padding: 28px;
    text-align: center;
    border-top: 3px solid var(--color-navy);
  }

  .test-card-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 10px;
  }

  .test-card-description {
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .feature-list {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 24px;
    background: var(--color-bg-warm);
    border-radius: 4px;
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-navy-medium);
    width: 32px;
    height: 32px;
  }

  .feature-item strong {
    display: block;
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 6px;
  }

  .feature-item p {
    font-size: 0.9rem;
    color: var(--color-text-muted);
  }

  .case-list {
    max-width: 600px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 14px;
    list-style: disc;
    padding-left: 1.5em;
  }

  .case-list li {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .page-cta {
    background: white;
    padding: 64px 0;
    text-align: center;
  }

  .page-cta-text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 2;
    margin-bottom: 28px;
  }

  .page-cta-button {
    display: inline-block;
    background: var(--color-navy);
    color: white;
    padding: 16px 48px;
    border-radius: 4px;
    font-size: 1rem;
    font-weight: 500;
    transition: background 0.2s;
  }

  .page-cta-button:hover {
    background: var(--color-navy-light);
  }

  .page-cta-button.line-button {
    background: #06C755;
  }

  .page-cta-button.line-button:hover {
    background: #05b34c;
  }

  .page-cta-note {
    margin-top: 14px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .page-section {
      padding: 60px 0;
    }

    .symptom-grid {
      grid-template-columns: 1fr 1fr;
    }

    .test-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
