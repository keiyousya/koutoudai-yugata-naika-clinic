---
import { Image } from "astro:assets";
import TwilightBackground from "./TwilightBackground.astro";
import interiorImage01 from "../assets/interior01.jpeg";
import interiorImage02 from "../assets/interior02.jpeg";
import interiorImage03 from "../assets/interior03.jpeg";
---

<section class="hero">
  <div class="hero-slideshow" id="heroSlideshow">
    <div class="hero-slide-wrapper">
      <Image src={interiorImage01} alt="" width={1600} class="hero-slide" />
    </div>
    <div class="hero-slide-wrapper">
      <Image src={interiorImage02} alt="" width={1600} class="hero-slide" />
    </div>
    <div class="hero-slide-wrapper">
      <Image src={interiorImage03} alt="" width={1600} class="hero-slide" />
    </div>
  </div>
  <div class="hero-content container">
    <p class="hero-catchphrase">夜21時まで診療｜土日も受診できる内科</p>
    <h1 class="hero-title">
      <span class="hero-title-main">勾当台夕方内科<br class="sp-br" />クリニック</span>
    </h1>
    <div class="hero-schedule">
      <table class="hero-schedule-table">
        <thead>
          <tr>
            <th class="schedule-label">診療時間</th>
            <th>月</th>
            <th>火</th>
            <th>水</th>
            <th>木</th>
            <th>金</th>
            <th class="weekend">土</th>
            <th class="weekend">日</th>
          </tr>
        </thead>
        <tbody>
          <tr>
            <td class="schedule-time">一般 17-19時</td>
            <td class="closed">―</td>
            <td class="closed">―</td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
          </tr>
          <tr class="fever-row">
            <td class="schedule-time">発熱 19-21時</td>
            <td class="closed">―</td>
            <td class="closed">―</td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
            <td class="open"><span class="dot"></span></td>
          </tr>
        </tbody>
      </table>
      <p class="hero-schedule-note">【最終受付】20:45　【休診日】月曜日・火曜日・祝日</p>
    </div>
    <p class="hero-access">勾当台公園駅から徒歩2分</p>
  </div>
  <!-- <a href="/#recruit" class="recruit-banner">
    <span class="recruit-label">スタッフ募集</span>
    <span class="recruit-text">受付事務を募集しています</span>
  </a> -->
  <TwilightBackground />
</section>

<style>
  .hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    padding-top: 172px;
    padding-bottom: 0;
    isolation: isolate;
    background: var(--color-navy);
  }

  .hero-slideshow {
    position: absolute;
    inset: 0;
    z-index: -1;
  }

  .hero-slide-wrapper {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 1.5s ease-in-out;
  }

  .hero-slide-wrapper.active {
    opacity: 1;
  }

  .hero-slide-wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(30, 58, 95, 0.4);
  }

  .hero-slide {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  @keyframes panLeftToRight {
    0% {
      object-position: 0% center;
    }
    100% {
      object-position: 100% center;
    }
  }

  .hero-content {
    text-align: center;
    z-index: 1;
  }

  .hero-catchphrase {
    font-size: 1.15rem;
    color: #ffffff;
    margin-bottom: 20px;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-shadow: 0 1px 8px rgba(0, 0, 0, 0.4);
  }

  .hero-title {
    margin-bottom: 32px;
  }

  .hero-title-main {
    display: block;
    font-size: 2.2rem;
    font-weight: 700;
    color: #fff;
    letter-spacing: 0.06em;
    line-height: 1.4;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.4);
  }

  .sp-br {
    display: none;
  }

  .hero-schedule {
    margin: 0 auto 32px;
    max-width: 520px;
    background: #2a4e78;
    padding: 16px 16px 18px;
    border-radius: 6px;
  }

  .hero-schedule-table {
    width: 100%;
    border-collapse: collapse;
  }

  /* ヘッダー行: 白背景（紺の内側にマージンを持つ） */
  .hero-schedule-table thead tr {
    background: white;
  }

  .hero-schedule-table th {
    padding: 8px 0;
    text-align: center;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    color: var(--color-navy);
    vertical-align: middle;
  }

  .hero-schedule-table th.weekend {
    color: #d03030;
  }

  .schedule-label {
    width: 130px;
    letter-spacing: 0.25em !important;
  }

  /* データ行: 紺背景・白文字 */
  .hero-schedule-table td {
    padding: 10px 0;
    text-align: center;
    vertical-align: middle;
    color: white;
  }

  .schedule-time {
    font-weight: 700;
    font-size: 0.65rem !important;
    letter-spacing: 0.03em;
    width: 110px;
  }

  .hero-schedule-table td.closed {
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.9rem !important;
    font-weight: 400;
  }

  .fever-row td {
    border-top: 1px solid rgba(255, 255, 255, 0.15);
  }

  .dot {
    display: inline-block;
    width: 18px;
    height: 18px;
    background: #e8a04c;
    border-radius: 50%;
  }

  /* 休診日注記: 紺背景の中 */
  .hero-schedule-note {
    padding: 0 16px;
    margin-top: 0;
    font-size: 0.65rem;
    font-weight: 500;
    color: rgba(255, 255, 255, 0.9);
  }

  .note-sub {
    font-size: 0.9rem;
    font-weight: 400;
    color: rgba(255, 255, 255, 0.5);
    margin-left: 6px;
  }

  .hero-access {
    font-size: 0.9rem;
    color: #ffffff;
    margin-bottom: 36px;
    font-weight: 500;
    text-shadow: 0 1px 6px rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 768px) {
    .hero {
      min-height: calc(100vh - 20px);
      padding: 180px 0 60px;
    }

    .hero-catchphrase {
      font-size: 0.9rem;
    }

    .hero-title-main {
      font-size: 1.6rem;
    }

    .hero-slide {
      object-position: 100% center;
      animation: panLeftToRight 6.5s linear forwards;
    }

    .hero-schedule {
      max-width: 100%;
      padding: 10px 8px 12px;
    }

    .hero-schedule-table th {
      padding: 7px 0;
      font-size: 0.9rem;
      letter-spacing: 0.1em;
    }

    .hero-schedule-table td {
      padding: 8px 0;
    }

    .schedule-label {
      width: auto;
      padding: 0 8px;
      letter-spacing: 0.12em !important;
    }

    .schedule-time {
      width: auto;
      padding: 0 4px;
      font-size: 0.65rem !important;
      white-space: nowrap;
    }

    .dot {
      width: 14px;
      height: 14px;
    }

    .hero-schedule-table td.closed {
      font-size: 0.65rem !important;
    }

    .hero-schedule-note {
      font-size: 0.65rem;
      padding: 0 8px;
    }

    .hero-access {
      font-size: 0.9rem;
    }

  }

  @media (max-width: 480px) {
    .sp-br {
      display: inline;
    }
  }

  .recruit-banner {
    position: absolute;
    bottom: 40px;
    left: 50%;
    transform: translateX(-50%);
    z-index: 10;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    gap: 18px;
    width: fit-content;
    max-width: min(90%, 1100px);
    padding: 18px 36px;
    background: rgba(255, 255, 255, 0.95);
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 4px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: opacity 0.2s;
  }

  .recruit-banner:hover {
    opacity: 0.9;
  }

  .recruit-label {
    display: inline-block;
    padding: 5px 12px;
    background: var(--color-orange);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 3px;
    letter-spacing: 0.03em;
  }

  .recruit-text {
    color: var(--color-navy);
    font-size: 0.82rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .recruit-banner {
      gap: 10px;
      padding: 10px 16px;
      width: 90%;
    }

    .recruit-label {
      font-size: 0.65rem;
      padding: 4px 10px;
    }

    .recruit-text {
      font-size: 0.7rem;
    }
  }
</style>

<script>
  const wrappers = document.querySelectorAll<HTMLElement>(".hero-slide-wrapper");
  const twilight = document.querySelector<HTMLElement>(".twilight-bg");
  const stars = document.querySelector<HTMLElement>(".stars");
  const shootingStars = document.querySelectorAll<HTMLElement>(".shooting-star");
  const skyline = document.querySelector<HTMLElement>(".skyline");

  if (wrappers.length > 0) {
    let current = -1; // -1 = twilight background
    const total = wrappers.length;
    const interval = 5000;

    function showTwilight() {
      wrappers.forEach((w) => w.classList.remove("active"));
      if (twilight) twilight.style.opacity = "1";
      if (stars) stars.style.opacity = "1";
      shootingStars.forEach((s) => (s.style.opacity = ""));
      if (skyline) skyline.style.opacity = "";
    }

    function showSlide(index: number) {
      wrappers.forEach((w) => w.classList.remove("active"));
      if (twilight) twilight.style.opacity = "0";
      if (stars) stars.style.opacity = "0";
      shootingStars.forEach((s) => (s.style.opacity = "0"));
      if (skyline) skyline.style.opacity = "0";

      // アニメーションをリセット
      const slide = wrappers[index].querySelector<HTMLElement>(".hero-slide");
      if (slide) {
        slide.style.animation = "none";
        slide.offsetHeight; // reflowを強制
        slide.style.animation = "";
      }

      wrappers[index].classList.add("active");
    }

    // Start with twilight
    showTwilight();

    setInterval(() => {
      current++;
      if (current >= total) {
        current = -1;
        showTwilight();
      } else {
        showSlide(current);
      }
    }, interval);
  }
</script>
