---
import HealthIcon from "./HealthIcon.astro";
---

<section class="immunotherapy-banner">
  <div class="container">
    <div class="banner-content">
      <div class="banner-icon">
        <HealthIcon name="symbols/cardiogram_e" size={32} />
      </div>
      <div class="banner-text">
        <h3 class="banner-title">アレルゲン免疫療法を開始しました</h3>
        <p class="banner-description">
          スギ花粉症・ダニアレルギーの根本的な体質改善を目指す治療法です。保険適用で、夜間・土日も対応しています。
        </p>
        <a href="/allergen-immunotherapy" class="banner-link">
          詳しくはこちら →
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .immunotherapy-banner {
    background: var(--color-coral-bg);
    padding: 48px 0;
  }

  .banner-content {
    max-width: 900px;
    margin: 0 auto;
    display: flex;
    align-items: flex-start;
    gap: 28px;
    background: white;
    border-radius: 16px;
    padding: 36px 40px;
  }

  .banner-icon {
    flex-shrink: 0;
    width: 56px;
    height: 56px;
    background: var(--color-coral-bg);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-coral);
  }

  .banner-text {
    flex: 1;
  }

  .banner-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-navy);
    margin-bottom: 12px;
    line-height: 1.6;
  }

  .banner-description {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 18px;
  }

  .banner-link {
    display: inline-block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-coral);
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .banner-link:hover {
    opacity: 0.7;
  }

  @media (max-width: 768px) {
    .immunotherapy-banner {
      padding: 32px 0;
    }

    .banner-content {
      flex-direction: column;
      gap: 20px;
      padding: 28px 24px;
    }

    .banner-icon {
      width: 48px;
      height: 48px;
    }

    .banner-icon svg {
      width: 24px;
      height: 24px;
    }

    .banner-title {
      font-size: 1rem;
    }

    .banner-description {
      font-size: 0.88rem;
    }

    .banner-link {
      display: block;
      text-align: right;
      margin-top: 8px;
    }
  }
</style>
