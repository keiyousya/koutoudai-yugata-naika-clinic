---
interface Props {
  label?: string;
}

const { label = 'ワンポイント' } = Astro.props;
---

<div class="callout" data-label={label}>
  <slot />
</div>

<style>
  .callout {
    position: relative;
    border: 2px solid var(--color-turquoise);
    padding: 32px 24px 24px;
    margin: 40px 0;
    background: white;
    border-radius: 20px;
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .callout::before {
    content: attr(data-label);
    position: absolute;
    top: -14px;
    left: 20px;
    background: var(--color-turquoise);
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    padding: 4px 14px 4px 32px;
    border-radius: 20px;
    letter-spacing: 0.05em;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 48 48' fill='none' xmlns='http://www.w3.org/2000/svg'%3E%3Ccircle cx='24' cy='24' r='16' fill='white'/%3E%3Cpath d='M22 35C22 36.1046 22.8954 37 24 37C25.1046 37 26 36.1046 26 35V21C26 19.8954 25.1046 19 24 19C22.8954 19 22 19.8954 22 21V35Z' fill='%233eb8c8'/%3E%3Cpath d='M24 15C22.8954 15 22 14.1046 22 13C22 11.8954 22.8954 11 24 11C25.1046 11 26 11.8954 26 13C26 14.1046 25.1046 15 24 15Z' fill='%233eb8c8'/%3E%3C/svg%3E");
    background-size: 20px 20px;
    background-repeat: no-repeat;
    background-position: 8px center;
  }

  .callout :global(p) {
    margin-bottom: 0;
  }

  .callout :global(strong) {
    color: var(--color-turquoise-dark);
  }
</style>
