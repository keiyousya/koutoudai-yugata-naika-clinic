---
import LineButton from "./LineButton.astro";

interface Props {
  lines?: string[];
  showIntro?: boolean;
}

const { lines = [], showIntro = false } = Astro.props;
---

<div class="line-cta">
  {showIntro && (
    <p class="line-cta-intro">
      当院ではLINEからのご予約を<br />お願いしております。
    </p>
  )}
  {lines.length > 0 && (
    <p class="line-cta-text">
      {lines.map((line) => (
        <span class="cta-line">{line}</span>
      ))}
    </p>
  )}
  <LineButton />
  <p class="line-cta-note">
    友だち追加後、トーク画面よりご予約ください<br />
    予約なしでも受診いただけます
  </p>
</div>

<style>
  .line-cta {
    text-align: center;
  }

  .line-cta-intro {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 20px;
  }

  .line-cta-text {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 2;
    margin-bottom: 28px;
  }

  .cta-line {
    display: block;
  }

  .line-cta-note {
    margin-top: 20px;
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.8;
  }
</style>
