---
import { Image } from "astro:assets";
import interiorImage01 from "../assets/interior01.jpeg";
import interiorImage02 from "../assets/interior02.jpeg";
import interiorImage03 from "../assets/interior03.jpeg";
import ecgImage from "../assets/ecg.jpeg";
import echoImage from "../assets/echo.jpeg";
---

<section id="about" class="section about">
  <div class="container">
    <h2 class="section-title">当院について</h2>
    <div class="about-content">
      <div class="about-text">
        <p class="about-lead">
          お仕事帰りや夕方のお時間に、<br class="sp-only" />気軽に受診できるクリニックです。
        </p>
        <p class="about-description">
          生活習慣病など慢性疾患の継続的な管理から、急な発熱や体調不良への対応まで、<br />
          夕方以降のかかりつけ医として、お気軽にご相談ください。
        </p>

        <div class="interior-gallery">
          <div class="interior-image-wrapper">
            <Image src={interiorImage01} alt="受付・待合室" width={560} class="interior-image" />
            <span class="interior-label">受付・待合室</span>
          </div>
          <div class="interior-image-wrapper">
            <Image src={interiorImage02} alt="診察室" width={560} class="interior-image" />
            <span class="interior-label">診察室</span>
          </div>
          <div class="interior-image-wrapper">
            <Image src={interiorImage03} alt="処置室" width={560} class="interior-image" />
            <span class="interior-label">処置室</span>
          </div>
        </div>

        <ul class="about-features">
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <polyline points="12 6 12 12 16 14"/>
              </svg>
            </span>
            <div>
              <strong>夕方〜夜間診療</strong>
              <p>17:00〜21:00まで診療。お仕事帰りにも立ち寄れます。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/>
                <line x1="16" y1="2" x2="16" y2="6"/>
                <line x1="8" y1="2" x2="8" y2="6"/>
                <line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
            </span>
            <div>
              <strong>土日も診療</strong>
              <p>平日だけでなく、土曜・日曜も診療を行っています。</p>
            </div>
          </li>
          <li class="feature-item">
            <span class="feature-icon">
              <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
                <circle cx="12" cy="10" r="3"/>
              </svg>
            </span>
            <div>
              <strong>駅から徒歩2分</strong>
              <p>地下鉄南北線 勾当台公園駅から徒歩2分の好アクセス。</p>
            </div>
          </li>
        </ul>

        <div class="medical-area">
          <h3 class="medical-heading">診療内容</h3>
          <p class="medical-note">
            下記以外の症状もお気軽にご相談ください。必要に応じて専門医療機関へのご紹介も行います。
          </p>
          <div class="medical-columns">
            <div class="medical-card">
              <div class="medical-card-header">
                <span class="medical-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/>
                    <rect x="8" y="2" width="8" height="4" rx="1" ry="1"/>
                    <line x1="9" y1="12" x2="15" y2="12"/>
                    <line x1="9" y1="16" x2="15" y2="16"/>
                  </svg>
                </span>
                <h4 class="medical-card-title">慢性疾患のかかりつけ</h4>
              </div>
              <p class="medical-card-description">
                夕方以降の時間帯で継続的に生活習慣病などの管理・治療を行います。
              </p>
              <ul class="condition-list">
                <li class="condition-tag">高血圧</li>
                <li class="condition-tag">糖尿病</li>
                <li class="condition-tag">脂質異常症</li>
                <li class="condition-tag">高尿酸血症・痛風</li>
                <li class="condition-tag">甲状腺疾患</li>
                <li class="condition-tag">貧血</li>
              </ul>
            </div>

            <div class="medical-card">
              <div class="medical-card-header">
                <span class="medical-card-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/>
                  </svg>
                </span>
                <h4 class="medical-card-title">夜間の急な症状にも対応</h4>
              </div>
              <p class="medical-card-description">
                夕方以降の急な発熱や体調不良に対応します。
              </p>
              <ul class="condition-list">
                <li class="condition-tag">発熱・感冒症状</li>
                <li class="condition-tag">咳・喉の痛み</li>
                <li class="condition-tag">腹痛・下痢・嘔吐</li>
                <li class="condition-tag">花粉症・アレルギー</li>
                <li class="condition-tag">頻尿・排尿時痛</li>
              </ul>
            </div>
          </div>
        </div>

        <div class="exam-area">
          <h3 class="medical-heading">検査・設備</h3>
          <p class="medical-note">
            院内で実施できる検査のご案内です。
          </p>
          <div class="exam-grid">
            <div class="exam-item">
              <div class="exam-item-header">
                <span class="exam-item-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/>
                    <line x1="8" y1="21" x2="16" y2="21"/>
                    <line x1="12" y1="17" x2="12" y2="21"/>
                  </svg>
                </span>
                <h4 class="exam-item-title">超音波検査（エコー）</h4>
              </div>
              <p class="exam-item-description">
                腹部・腎泌尿器・頸動脈・甲状腺などの検査を行います。
              </p>
              <Image src={echoImage} alt="超音波検査装置" width={400} class="exam-item-image" />
              <span class="exam-item-device">キャノンメディカルシステムズ Aplio go / LE</span>
            </div>

            <div class="exam-item">
              <div class="exam-item-header">
                <span class="exam-item-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 12h-4l-3 9L9 3l-3 9H2"/>
                  </svg>
                </span>
                <h4 class="exam-item-title">12誘導心電図</h4>
              </div>
              <p class="exam-item-description">
                不整脈や狭心症など、心臓に関わる症状の評価に用います。
              </p>
              <Image src={ecgImage} alt="12誘導心電図" width={400} class="exam-item-image" />
              <span class="exam-item-device">日本光電 ECG-3250</span>
            </div>

            <div class="exam-item">
              <div class="exam-item-header">
                <span class="exam-item-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <circle cx="12" cy="12" r="5"/>
                    <line x1="12" y1="3" x2="12" y2="5"/>
                    <line x1="12" y1="19" x2="12" y2="21"/>
                    <line x1="3" y1="12" x2="5" y2="12"/>
                    <line x1="19" y1="12" x2="21" y2="12"/>
                    <line x1="5.64" y1="5.64" x2="7.05" y2="7.05"/>
                    <line x1="16.95" y1="16.95" x2="18.36" y2="18.36"/>
                    <line x1="5.64" y1="18.36" x2="7.05" y2="16.95"/>
                    <line x1="16.95" y1="7.05" x2="18.36" y2="5.64"/>
                  </svg>
                </span>
                <h4 class="exam-item-title">迅速抗原検査</h4>
              </div>
              <p class="exam-item-description">
                院内で短時間に結果が得られる検査です。
              </p>
              <ul class="condition-list">
                <li class="condition-tag">インフルエンザA / B</li>
                <li class="condition-tag">新型コロナウイルス</li>
                <li class="condition-tag">溶連菌</li>
              </ul>
            </div>

            <div class="exam-item">
              <div class="exam-item-header">
                <span class="exam-item-icon">
                  <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 2l4 4-9.5 9.5-4-4z"/>
                    <path d="M8.5 15.5L2 22"/>
                    <line x1="15" y1="9" x2="9.5" y2="14.5"/>
                  </svg>
                </span>
                <h4 class="exam-item-title">検体検査</h4>
              </div>
              <p class="exam-item-description">
                血液検査・尿検査などは外部検査機関に委託して実施します。結果は後日お伝えいたします。
              </p>
            </div>
          </div>
        </div>

        <div class="prescription-area">
          <h3 class="medical-heading">お薬の処方について</h3>
          <div class="prescription-box">
            <p class="prescription-text">
              当院では原則として<strong>院外処方</strong>となります。<br />
              近隣の調剤薬局が閉まっている時間帯に限り、急性疾患に対する一部のお薬を<strong>院内でお渡し</strong>できる場合があります。
            </p>
          </div>
          <p class="prescription-note">
            ※ 降圧薬・糖尿病治療薬などの慢性疾患のお薬は院外処方のみとなります。
          </p>
        </div>

        <div class="insurance-area">
          <h3 class="medical-heading">保険証について</h3>
          <div class="insurance-notice">
            <p class="insurance-notice-label">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"/>
                <line x1="12" y1="8" x2="12" y2="12"/>
                <line x1="12" y1="16" x2="12.01" y2="16"/>
              </svg>
              オンライン資格確認システム導入までのご案内
            </p>
            <p class="insurance-notice-text">
              当院では現在オンライン資格確認システムの導入準備中のため、マイナンバーカードの読み取りによる保険資格の確認ができません。<br />
              ご来院の際は、以下のいずれかをお持ちください。
            </p>
            <ul class="insurance-list">
              <li>
                <strong>健康保険証</strong>または<strong>資格確認書</strong>
              </li>
              <li>
                <strong>マイナ保険証</strong>をご利用の方は、保険の資格情報がわかるものを併せてお持ちください
                <ul class="insurance-sublist">
                  <li>「資格情報のお知らせ」（紙の通知書）</li>
                  <li>マイナポータルの資格情報画面（スマートフォン表示またはPDF）</li>
                </ul>
              </li>
            </ul>
          </div>
          <p class="insurance-note">
            ※ オンライン資格確認の導入後は、マイナンバーカードのみで受診いただけるようになります。
          </p>
        </div>
        <div class="payment-area">
          <h3 class="medical-heading">お支払いについて</h3>
          <p class="payment-text">
            現金・クレジットカード等キャッシュレス決済に対応しています。<br />
            ※ 保険証をお忘れの場合は10割負担での現金払いとなります。後日保険証をお持ちいただければ差額を返金いたします。
          </p>
        </div>

      </div>
    </div>
  </div>
</section>

<style>
  .about {
    background: white;
  }

  .about-content {
    max-width: 960px;
    margin: 0 auto;
  }

  .about-lead {
    font-size: 1.15rem;
    font-weight: 500;
    color: var(--color-navy);
    text-align: center;
    margin-bottom: 24px;
    line-height: 1.9;
  }

  .about-description {
    text-align: center;
    color: var(--color-text-secondary);
    margin-bottom: 48px;
    line-height: 1.9;
    font-size: 0.9rem;
  }

  .about-features {
    display: grid;
    gap: 28px;
  }

  .feature-item {
    display: flex;
    align-items: flex-start;
    gap: 18px;
    padding: 24px;
    background: var(--color-bg-warm);
    border-radius: 4px;
    border-bottom: 1px solid var(--color-border);
  }

  .feature-icon {
    flex-shrink: 0;
    color: var(--color-navy-medium);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    margin-top: 2px;
  }

  .feature-item strong {
    display: block;
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 8px;
  }

  .feature-item p {
    color: var(--color-text-muted);
    font-size: 0.9rem;
  }

  .medical-area {
    margin-top: 64px;
  }

  .medical-heading {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-navy);
    text-align: center;
    margin-bottom: 14px;
    letter-spacing: 0.04em;
  }

  .medical-columns {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
    margin-bottom: 32px;
  }

  .medical-card {
    background: var(--color-bg-blue);
    border-radius: 4px;
    padding: 28px 24px;
    border-top: 2px solid var(--color-navy);
  }

  .medical-card-header {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 12px;
  }

  .medical-card-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: white;
    border-radius: 4px;
    color: var(--color-navy-medium);
  }

  .medical-card-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
    line-height: 1.4;
  }

  .medical-card-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 18px;
  }

  .condition-list {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .condition-tag {
    display: inline-block;
    padding: 5px 12px;
    background: white;
    color: var(--color-text);
    font-size: 0.9rem;
    font-weight: 400;
    border-radius: 3px;
    border: 1px solid var(--color-border);
  }

  .medical-note {
    text-align: center;
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    margin-bottom: 28px;
  }

  .interior-gallery {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin-bottom: 48px;
  }

  .interior-image-wrapper {
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--color-border);
    position: relative;
  }

  .interior-image {
    display: block;
    width: 100%;
    height: auto;
  }

  .interior-label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 6px 12px;
    background: rgba(0, 0, 0, 0.5);
    color: white;
    font-size: 0.78rem;
    font-weight: 500;
    text-align: center;
  }


  .exam-area {
    margin-top: 64px;
  }

  .exam-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 28px;
  }

  .exam-item {
    background: var(--color-bg-warm);
    border-radius: 4px;
    padding: 24px;
    border-left: 3px solid var(--color-navy-medium);
  }

  .exam-item-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
  }

  .exam-item-icon {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-navy-medium);
    position: relative;
    top: 1px;
  }

  .exam-item-title {
    font-size: 0.95rem;
    font-weight: 700;
    color: var(--color-navy);
  }

  .exam-item-description {
    color: var(--color-text-muted);
    font-size: 0.9rem;
    line-height: 1.8;
    margin-bottom: 12px;
  }

  .exam-item-image {
    width: 100%;
    height: auto;
    border-radius: 4px;
    margin-bottom: 12px;
  }

  .exam-item-device {
    display: inline-block;
    font-size: 0.78rem;
    color: var(--color-text-muted);
    border-top: 1px solid var(--color-border);
    padding-top: 10px;
    width: 100%;
  }

  .insurance-area {
    margin-top: 64px;
  }

  .insurance-notice {
    max-width: 720px;
    margin: 0 auto;
    background: #fdf8f0;
    border-radius: 4px;
    padding: 28px 32px;
    border-left: 3px solid var(--color-orange);
  }

  .insurance-notice-label {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-orange);
    margin-bottom: 14px;
  }

  .insurance-notice-label svg {
    position: relative;
    top: 1px;
  }

  .insurance-notice-text {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.9;
    margin-bottom: 16px;
  }

  .insurance-list {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.9;
    margin-bottom: 16px;
    padding-left: 1.2em;
    list-style: disc;
  }

  .insurance-list > li {
    margin-bottom: 10px;
  }

  .insurance-sublist {
    padding-left: 1.2em;
    list-style: circle;
    margin-top: 4px;
    color: var(--color-text-muted);
    font-size: 0.85rem;
  }

  .insurance-note {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 720px;
    margin: 10px auto 0;
    text-align: center;
  }

  .prescription-area {
    margin-top: 64px;
  }

  .prescription-box {
    max-width: 720px;
    margin: 0 auto;
    background: var(--color-bg-blue);
    border-radius: 4px;
    padding: 28px 32px;
    border-top: 2px solid var(--color-navy);
  }

  .prescription-text {
    font-size: 0.9rem;
    color: var(--color-text);
    line-height: 1.9;
    margin-bottom: 14px;
  }

  .prescription-note {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.8;
    max-width: 720px;
    margin: 10px auto 0;
    text-align: center;
  }

  .payment-area {
    margin-top: 64px;
  }

  .payment-text {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    line-height: 1.9;
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }


  .sp-only {
    display: none;
  }

  @media (max-width: 768px) {
    .sp-only {
      display: inline;
    }

    .about-lead {
      font-size: 1rem;
    }

    .about-description {
      font-size: 0.9rem;
      text-align: left;
    }

    .feature-item {
      padding: 18px;
    }

    .feature-icon svg {
      width: 24px;
      height: 24px;
    }

    .medical-area {
      margin-top: 40px;
    }

    .medical-heading {
      font-size: 1rem;
      margin-bottom: 20px;
    }

    .medical-columns {
      grid-template-columns: 1fr;
      gap: 28px;
    }

    .medical-card {
      padding: 22px 18px;
    }

    .medical-card-title {
      font-size: 0.9rem;
    }

