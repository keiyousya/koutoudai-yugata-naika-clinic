{
  "name": "koutoudai-yugata-naika-clinic",
  "private": true,
  "scripts": {
    "dev": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter frontend dev\"",
    "dev:frontend": "pnpm --filter frontend dev",
    "dev:backend": "pnpm --filter backend dev",
    "dev:admin": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter admin dev\"",
    "dev:timecard": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter timecard dev\"",
    "dev:shift": "concurrently \"pnpm --filter backend dev\" \"pnpm --filter shift dev\"",
    "admin:prod": "pnpm --filter admin dev --mode production",
    "build": "pnpm --filter frontend build",
    "build:timecard": "pnpm --filter timecard build",
    "build:shift": "pnpm --filter shift build",
    "build:manuals": "pnpm --filter manuals build",
    "dev:manuals": "pnpm --filter manuals dev",
    "deploy:api": "pnpm --filter backend run deploy"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
