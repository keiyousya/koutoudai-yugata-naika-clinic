---
// クライアントサイドのパスワードゲート（再利用可能）。
// slot の中身を認証成功まで非表示にする。
//
// ※ 配信先が GitHub Pages（サーバー処理なし）のため本物のHTTP Basic認証は
//    使えず、これはクライアントサイドの簡易ゲート。中身はHTMLソースには残るため
//    暗号学的な秘匿ではない点に注意。
//
// 使い方:
//   <PasswordGate hash="<sha256(`${id}:${pw}`)>" storageKey="foo">
//     ...保護したい中身...
//   </PasswordGate>
//
// hash の求め方（例: id=admin / pw=secret）:
//   printf '%s' 'admin:secret' | shasum -a 256
interface Props {
  /** sha256(`${id}:${password}`) の16進文字列 */
  hash: string;
  /** ページ単位で認証状態を分けるためのキー（sessionStorage） */
  storageKey?: string;
  title?: string;
  description?: string;
}

const {
  hash,
  storageKey = "auth",
  title = "認証が必要です",
  description = "このページは公開準備中です。閲覧には認証が必要です。",
} = Astro.props;
---

<div id="pg-gate" class="pg-gate" data-hash={hash} data-key={storageKey}>
  <form id="pg-form" class="pg-box" autocomplete="off">
    <h1 class="pg-title">{title}</h1>
    <p class="pg-desc">{description}</p>
    <label class="pg-label">ID<input type="text" id="pg-id" class="pg-input" autocomplete="username" required /></label>
    <label class="pg-label">パスワード<input type="password" id="pg-pw" class="pg-input" autocomplete="current-password" required /></label>
    <p id="pg-error" class="pg-error" hidden>IDまたはパスワードが正しくありません。</p>
    <button type="submit" class="pg-btn">ログイン</button>
  </form>
</div>

<div id="pg-content" hidden><slot /></div>

<script>
  (function () {
    const gate = document.getElementById("pg-gate");
    const content = document.getElementById("pg-content");
    const form = document.getElementById("pg-form");
    const errorEl = document.getElementById("pg-error");
    if (!gate || !content || !form) return;

    const expected = gate.getAttribute("data-hash");
    const KEY = "pg_" + (gate.getAttribute("data-key") || "auth");

    async function sha256(str: string) {
      const buf = await crypto.subtle.digest("SHA-256", new TextEncoder().encode(str));
      return Array.from(new Uint8Array(buf)).map((b) => b.toString(16).padStart(2, "0")).join("");
    }

    function unlock() {
      gate!.setAttribute("hidden", "");
      (gate as HTMLElement).style.display = "none";
      content!.removeAttribute("hidden");
      document.body.style.overflow = "";
    }

    let authed = false;
    try {
      authed = sessionStorage.getItem(KEY) === expected;
    } catch (e) {}
    if (authed) {
      unlock();
      return;
    }

    // ゲート表示中は背面のスクロールを抑止
    document.body.style.overflow = "hidden";

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      const id = (document.getElementById("pg-id") as HTMLInputElement).value.trim();
      const pw = (document.getElementById("pg-pw") as HTMLInputElement).value;
      const hash = await sha256(id + ":" + pw);
      if (hash === expected) {
        try {
          sessionStorage.setItem(KEY, expected as string);
        } catch (e) {}
        unlock();
      } else if (errorEl) {
        errorEl.removeAttribute("hidden");
      }
    });
  })();
</script>

<style>
  #pg-content[hidden] {
    display: none;
  }

  .pg-gate {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: var(--color-bg-blue);
  }

  .pg-box {
    width: 100%;
    max-width: 360px;
    background: white;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 32px 28px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.08);
  }

  .pg-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-navy);
    text-align: center;
    margin-bottom: 8px;
  }

  .pg-desc {
    font-size: 0.8rem;
    color: var(--color-text-muted);
    text-align: center;
    line-height: 1.7;
    margin-bottom: 24px;
  }

  .pg-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 16px;
  }

  .pg-input {
    display: block;
    width: 100%;
    margin-top: 6px;
    padding: 10px 12px;
    font-size: 0.95rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    box-sizing: border-box;
  }

  .pg-input:focus {
    outline: none;
    border-color: var(--color-turquoise);
  }

  .pg-error {
    font-size: 0.8rem;
    color: var(--color-coral);
    margin-bottom: 12px;
  }

  .pg-btn {
    width: 100%;
    padding: 12px;
    background: var(--color-navy);
    color: white;
    font-size: 0.95rem;
    font-weight: 700;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: opacity 0.2s;
  }

  .pg-btn:hover {
    opacity: 0.88;
  }
</style>
