---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Hero from "../components/Hero.astro";
import About from "../components/About.astro";
import Hours from "../components/Hours.astro";
import Access from "../components/Access.astro";
import Reservation from "../components/Reservation.astro";
import News from "../components/News.astro";
import Articles from "../components/Articles.astro";
import Doctor from "../components/Doctor.astro";
import AppropriateCareBanner from "../components/AppropriateCareBanner.astro";
import InsuranceBanner from "../components/InsuranceBanner.astro";
import DisclosureLinks from "../components/DisclosureLinks.astro";
import Footer from "../components/Footer.astro";
---

<Layout
  title="勾当台夕方内科クリニック | 仙台で夜21時まで診療・健診再検査・アフターピル処方"
  description="仙台市で夜21時まで診療の内科クリニック。発熱・咳・風邪症状、健診再検査、緊急避妊薬（アフターピル）夜間処方、性感染症検査に対応。土日も診療、勾当台公園駅徒歩2分。"
>
  <Header />
  <main>
    <Hero />
    <InsuranceBanner />
    <News />
    <AppropriateCareBanner />
    <DisclosureLinks />
    <About />
    <Hours />
    <Reservation />
    <Access />
    <Articles />
    <Doctor />
  </main>
  <Footer />
</Layout>
