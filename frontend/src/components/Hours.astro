---
// 6月までのスケジュール（1段のみ）
const scheduleJune = [
  { day: "月", open: false },
  { day: "火", open: false },
  { day: "水", open: true },
  { day: "木", open: true },
  { day: "金", open: true },
  { day: "土", open: true },
  { day: "日", open: true },
];

// 7月からのスケジュール（2段）
const days = ["月", "火", "水", "木", "金", "土", "日"];
// 14-17時: 土日のみ
const scheduleJuly14 = [
  { day: "月", open: false, na: true },
  { day: "火", open: false, na: true },
  { day: "水", open: false, na: true },
  { day: "木", open: false, na: true },
  { day: "金", open: false, na: true },
  { day: "土", open: true },
  { day: "日", open: true },
];
// 17-21時: 火曜以外
const scheduleJuly17 = [
  { day: "月", open: true },
  { day: "火", open: false, na: true },
  { day: "水", open: true },
  { day: "木", open: true },
  { day: "金", open: true },
  { day: "土", open: true },
  { day: "日", open: true },
];

// 2026年6月の診療カレンダー（日曜始まり）
const june2026 = [
  { day: null },
  { day: 1, open: false },
  { day: 2, open: false },
  { day: 3, open: true },
  { day: 4, open: true },
  { day: 5, open: true },
  { day: 6, open: true },
  { day: 7, open: false, temporary: true },
  { day: 8, open: false },
  { day: 9, open: false },
  { day: 10, open: true },
  { day: 11, open: true },
  { day: 12, open: true },
  { day: 13, open: true },
  { day: 14, open: true },
  { day: 15, open: false },
  { day: 16, open: false },
  { day: 17, open: true },
  { day: 18, open: true },
  { day: 19, open: true },
  { day: 20, open: true },
  { day: 21, open: true },
  { day: 22, open: false },
  { day: 23, open: false },
  { day: 24, open: true },
  { day: 25, open: true },
  { day: 26, open: true },
  { day: 27, open: true },
  { day: 28, open: true },
  { day: 29, open: false },
  { day: 30, open: false },
];

// 2026年7月の診療カレンダー（日曜始まり）
// 7月から月曜も診療日
const july2026 = [
  { day: null }, { day: null }, { day: null },
  { day: 1, open: true },
  { day: 2, open: true },
  { day: 3, open: true },
  { day: 4, open: true },
  { day: 5, open: true },
  { day: 6, open: true },  // 月曜（7月から診療日）
  { day: 7, open: false },
  { day: 8, open: true },
  { day: 9, open: true },
  { day: 10, open: true },
  { day: 11, open: true },
  { day: 12, open: true },
  { day: 13, open: true },  // 月曜（7月から診療日）
  { day: 14, open: false },
  { day: 15, open: true },
  { day: 16, open: true },
  { day: 17, open: true },
  { day: 18, open: true },
  { day: 19, open: true },
  { day: 20, open: false, holiday: true },  // 海の日（祝日）
  { day: 21, open: false },
  { day: 22, open: true },
  { day: 23, open: true },
  { day: 24, open: true },
  { day: 25, open: true },
  { day: 26, open: true },
  { day: 27, open: true },  // 月曜（7月から診療日）
  { day: 28, open: false },
  { day: 29, open: true },
  { day: 30, open: true },
  { day: 31, open: true },
];

const weekdays = ["日", "月", "火", "水", "木", "金", "土"];
---

<section id="hours" class="section hours">
  <div class="container">
    <h2 class="section-title">診療時間</h2>
    <div class="hours-layout">
      <!-- 左側：カレンダー -->
      <div class="calendar-side">
        <div class="month-tabs">
          <button class="month-tab active" data-month="0">6月</button>
          <button class="month-tab" data-month="1">7月</button>
        </div>

        <div class="calendar-container">
          <button class="calendar-nav prev" id="prevMonth" aria-label="前の月">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="15 18 9 12 15 6"/>
            </svg>
          </button>

          <div class="calendar-slider">
            <div class="calendar-track" id="calendarTrack">
              <div class="monthly-calendar">
                <div class="monthly-header">
                  <span>2026年6月</span>
                </div>
                <div class="monthly-weekdays">
                  {weekdays.map((day, i) => (
                    <div class={`weekday ${i === 0 ? "sunday" : ""} ${i === 6 ? "saturday" : ""}`}>{day}</div>
                  ))}
                </div>
                <div class="monthly-grid">
                  {june2026.map((item, i) => (
                    <div class={`monthly-cell ${item.day === null ? "empty" : ""} ${item.open ? "open" : "closed"} ${item.holiday ? "holiday" : ""} ${item.temporary ? "temporary" : ""}`}>
                      {item.day !== null && (
                        <>
                          <span class={`date ${i % 7 === 0 ? "sunday" : ""} ${i % 7 === 6 ? "saturday" : ""}`}>{item.day}</span>
                          <span class="status">{item.open ? "○" : "休"}</span>
                        </>
                      )}
                    </div>
                  ))}
                </div>
              </div>

              <div class="monthly-calendar">
                <div class="monthly-header">
                  <span>2026年7月</span>
                </div>
                <div class="monthly-weekdays">
                  {weekdays.map((day, i) => (
                    <div class={`weekday ${i === 0 ? "sunday" : ""} ${i === 6 ? "saturday" : ""}`}>{day}</div>
                  ))}
                </div>
                <div class="monthly-grid">
                  {july2026.map((item, i) => (
                    <div class={`monthly-cell ${item.day === null ? "empty" : ""} ${item.open ? "open" : "closed"} ${item.holiday ? "holiday" : ""} ${item.temporary ? "temporary" : ""}`}>
                      {item.day !== null && (
                        <>
                          <span class={`date ${i % 7 === 0 ? "sunday" : ""} ${i % 7 === 6 ? "saturday" : ""}`}>{item.day}</span>
                          <span class="status">{item.open ? "○" : "休"}</span>
                        </>
                      )}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          </div>

          <button class="calendar-nav next" id="nextMonth" aria-label="次の月">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="9 18 15 12 9 6"/>
            </svg>
          </button>
        </div>

        <div class="calendar-legend">
          <div class="legend-item">
            <span class="legend-icon open">○</span>
            <span>診療</span>
          </div>
          <div class="legend-item">
            <span class="legend-icon closed">休</span>
            <span>休診</span>
          </div>
          <div class="legend-item">
            <span class="legend-icon temporary">休</span>
            <span>臨時休診</span>
          </div>
        </div>
      </div>

      <!-- 右側：診療時間 -->
      <div class="info-side">
        <!-- 6月の診療時間 -->
        <div class="hours-main" id="hoursJune">
          <div class="hours-primary">17:00 - 21:00</div>
          <div class="hours-sub">発熱外来 19:00-21:00</div>
        </div>

        <!-- 7月からの注意書き -->
        <div class="new-hours-notice hidden" id="newHoursNotice">
          <span class="new-hours-badge">NEW</span>
          <span>7月より診療時間が変わります</span>
        </div>

        <!-- 7月からの診療時間 -->
        <div class="hours-main hidden" id="hoursJuly">
          <div class="hours-block">
            <span class="hours-block-label">平日（月・水〜金）</span>
            <div class="hours-primary">17:00 - 21:00</div>
            <div class="hours-sub">発熱外来 19:00-21:00</div>
          </div>
          <div class="hours-block">
            <span class="hours-block-label">土日</span>
            <div class="hours-primary">14:00 - 21:00</div>
            <div class="hours-sub">発熱外来 18:00-21:00</div>
          </div>
        </div>

        <div class="hours-last-reception">
          <span class="last-reception-text">最終受付 <strong>20:45</strong><br class="sp-only" />（LINE・電話予約の当日最終）</span>
        </div>

        <!-- 6月の診療日カレンダー -->
        <div class="schedule-table" id="scheduleJune">
          <div class="schedule-header">
            <span>診療日カレンダー</span>
          </div>
          <div class="schedule-grid">
            {
              scheduleJune.map((item) => (
                <div class={`schedule-cell ${item.open ? "open" : "closed"}`}>
                  <span class="day">{item.day}</span>
                  <span class="status">{item.open ? "○" : "休"}</span>
                </div>
              ))
            }
          </div>
        </div>

        <!-- 7月からの診療日カレンダー -->
        <div class="schedule-table two-rows hidden" id="scheduleJuly">
          <div class="schedule-header">
            <span>診療日カレンダー</span>
          </div>
          <div class="schedule-days">
            <div class="schedule-day-spacer"></div>
            {days.map((day) => (
              <div class="schedule-day-header">{day}</div>
            ))}
          </div>
          <div class="schedule-row">
            <div class="schedule-time-label">14-17時</div>
            <div class="schedule-grid-row">
              {scheduleJuly14.map((item) => (
                <div class={`schedule-cell ${item.open ? "open" : "closed"} ${item.na ? "na" : ""}`}>
                  <span class="status">{item.na ? "-" : (item.open ? "○" : "休")}</span>
                </div>
              ))}
            </div>
          </div>
          <div class="schedule-row">
            <div class="schedule-time-label">17-21時</div>
            <div class="schedule-grid-row">
              {scheduleJuly17.map((item) => (
                <div class={`schedule-cell ${item.open ? "open" : "closed"} ${item.na ? "na" : ""}`}>
                  <span class="status">{item.na ? "-" : (item.open ? "○" : "休")}</span>
                </div>
              ))}
            </div>
          </div>
        </div>

        <!-- 6月の診療日説明 -->
        <div class="hours-info" id="infoJune">
          <div class="info-item">
            <span class="info-icon open">○</span>
            <span>診療日（水〜日・週末対応）</span>
          </div>
          <div class="info-item">
            <span class="info-icon closed">休</span>
            <span>休診日（月・火・祝）</span>
          </div>
        </div>

        <!-- 7月からの診療日説明 -->
        <div class="hours-info hidden" id="infoJuly">
          <div class="info-item">
            <span class="info-icon open">○</span>
            <span>診療日（月・水〜日）</span>
          </div>
        </div>

        <div class="hours-notice">
          <p>
            ※急な休診の場合は、当院ウェブサイトにてお知らせいたします。
          </p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .hours {
    background: white;
  }

  .hidden {
    display: none !important;
  }

  .hours-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    max-width: 1100px;
    margin: 0 auto;
    align-items: start;
  }

  /* カレンダー側 */
  .calendar-side {
    width: 100%;
  }

  .month-tabs {
    display: flex;
    gap: 12px;
    margin-bottom: 20px;
    justify-content: center;
  }

  .month-tab {
    padding: 10px 28px;
    background: white;
    border: 2px solid var(--color-border);
    border-radius: 24px;
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-text-muted);
    cursor: pointer;
    transition: all 0.2s;
  }

  .month-tab:hover {
    border-color: var(--color-turquoise);
    color: var(--color-turquoise);
  }

  .month-tab.active {
    background: var(--color-turquoise);
    border-color: var(--color-turquoise);
    color: white;
  }

  .calendar-container {
    position: relative;
    margin-bottom: 20px;
  }

  .calendar-slider {
    overflow: hidden;
    border-radius: 16px;
  }

  .calendar-track {
    display: flex;
    transition: transform 0.3s ease-in-out;
  }

  .monthly-calendar {
    min-width: 100%;
    flex-shrink: 0;
    background: white;
    border: 1px solid #d0e8ec;
    border-radius: 16px;
    overflow: hidden;
  }

  .calendar-nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: white;
    border: 1px solid #d0e8ec;
    border-radius: 50%;
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--color-navy);
    transition: all 0.2s;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .calendar-nav:hover:not(:disabled) {
    background: var(--color-turquoise-bg);
    border-color: var(--color-turquoise);
    color: var(--color-turquoise);
  }

  .calendar-nav:disabled {
    cursor: not-allowed;
  }

  .calendar-nav.prev {
    left: -22px;
  }

  .calendar-nav.next {
    right: -22px;
  }

  .monthly-header {
    background: var(--color-navy);
    color: white;
    padding: 16px;
    text-align: center;
    font-weight: 600;
    font-size: 1.1rem;
    letter-spacing: 0.05em;
  }

  .monthly-weekdays {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    background: #f8f8f8;
    border-bottom: 1px solid var(--color-border);
  }

  .monthly-weekdays .weekday {
    text-align: center;
    padding: 10px 4px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .monthly-weekdays .weekday.sunday {
    color: #e05a5a;
  }

  .monthly-weekdays .weekday.saturday {
    color: #4a90d9;
  }

  .monthly-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
  }

  .monthly-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 12px 4px;
    border-right: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    min-height: 60px;
  }

  .monthly-cell:nth-child(7n) {
    border-right: none;
  }

  .monthly-cell.empty {
    background: #fafafa;
  }

  .monthly-cell.closed {
    background: #f9f9f9;
  }

  .monthly-cell.holiday {
    background: #f0f8f9;
  }

  .monthly-cell.temporary {
    background: #fff5e6;
  }

  .monthly-cell.temporary .status {
    color: #e07a30;
  }

  .monthly-cell .date {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-navy);
    margin-bottom: 4px;
  }

  .monthly-cell .date.sunday {
    color: #e05a5a;
  }

  .monthly-cell .date.saturday {
    color: #4a90d9;
  }

  .monthly-cell .status {
    font-size: 0.85rem;
    font-weight: 700;
  }

  .monthly-cell.open .status {
    color: var(--color-turquoise);
  }

  .monthly-cell.closed .status {
    color: #888;
  }

  .calendar-legend {
    display: flex;
    justify-content: center;
    gap: 24px;
    padding: 16px 20px;
    background: #fafafa;
    border-radius: 12px;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .legend-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    font-size: 0.8rem;
    font-weight: 700;
  }

  .legend-icon.open {
    background: var(--color-turquoise-bg);
    color: var(--color-turquoise);
  }

  .legend-icon.closed {
    background: #f5f5f5;
    color: #666;
  }

  .legend-icon.temporary {
    background: #fff5e6;
    color: #e07a30;
  }

  /* 診療時間側 */
  .info-side {
    width: 100%;
  }

  .new-hours-notice {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 12px 20px;
    margin-bottom: 16px;
    background: linear-gradient(135deg, #fff3e0 0%, #ffe0b2 100%);
    border: 1px solid #ffb74d;
    border-radius: 12px;
    font-size: 0.9rem;
    font-weight: 500;
    color: #e65100;
  }

  .new-hours-badge {
    display: inline-block;
    padding: 3px 8px;
    background: #ff6d00;
    color: white;
    font-size: 0.7rem;
    font-weight: 700;
    border-radius: 4px;
    letter-spacing: 0.05em;
  }

  .hours-main {
    text-align: center;
    margin-bottom: 24px;
    padding: 28px;
    background: var(--color-turquoise-bg);
    border-radius: 16px;
  }

  .hours-primary {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--color-navy);
    letter-spacing: 0.02em;
  }

  .hours-sub {
    font-size: 0.9rem;
    color: var(--color-text-muted);
    margin-top: 10px;
  }

  .hours-block {
    padding-bottom: 20px;
    margin-bottom: 20px;
    border-bottom: 1px solid rgba(62, 184, 200, 0.3);
  }

  .hours-block:last-child {
    padding-bottom: 0;
    margin-bottom: 0;
    border-bottom: none;
  }

  .hours-block-label {
    display: block;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-navy);
    margin-bottom: 10px;
  }

  .hours-last-reception {
    text-align: center;
    margin-bottom: 24px;
  }

  .last-reception-text {
    font-size: 1rem;
    color: var(--color-text-muted);
  }

  .last-reception-text strong {
    font-weight: 700;
    color: var(--color-navy);
  }

  .schedule-table {
    background: white;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid #d0e8ec;
    margin-bottom: 20px;
  }

  .schedule-header {
    background: var(--color-navy);
    color: white;
    padding: 12px;
    text-align: center;
    font-weight: 500;
    font-size: 0.85rem;
    letter-spacing: 0.03em;
  }

  .schedule-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
  }

  .schedule-cell {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 16px 6px;
    border-right: 1px solid var(--color-border);
  }

  .schedule-cell:last-child {
    border-right: none;
  }

  .schedule-cell .day {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    margin-bottom: 6px;
  }

  .schedule-cell .status {
    font-size: 1rem;
    font-weight: 700;
  }

  .schedule-cell.open .status {
    color: var(--color-turquoise);
  }

  .schedule-cell.closed .status {
    color: #888;
  }

  .schedule-cell.closed {
    background: #f9f9f9;
  }

  .schedule-cell.na {
    background: #fafafa;
  }

  .schedule-cell.na .status {
    color: #ccc;
  }

  /* 2段レイアウト用 */
  .schedule-table.two-rows .schedule-days {
    display: grid;
    grid-template-columns: 70px repeat(7, 1fr);
    background: #f8f8f8;
    border-bottom: 1px solid var(--color-border);
  }

  .schedule-day-spacer {
    border-right: 1px solid var(--color-border);
  }

  .schedule-day-header {
    text-align: center;
    padding: 10px 4px;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--color-text-muted);
  }

  .schedule-row {
    display: flex;
    border-bottom: 1px solid var(--color-border);
  }

  .schedule-row:last-child {
    border-bottom: none;
  }

  .schedule-time-label {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 70px;
    flex-shrink: 0;
    font-size: 0.65rem;
    font-weight: 500;
    color: var(--color-text-muted);
    background: #f8f8f8;
    border-right: 1px solid var(--color-border);
  }

  .schedule-grid-row {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    flex: 1;
  }

  .schedule-grid-row .schedule-cell {
    padding: 12px 4px;
  }

  .hours-info {
    display: flex;
    justify-content: center;
    gap: 24px;
    margin-bottom: 20px;
  }

  .info-item {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 0.85rem;
    color: var(--color-text-muted);
  }

  .info-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    font-size: 0.85rem;
    font-weight: 700;
  }

  .info-icon.open {
    background: var(--color-turquoise-bg);
    color: var(--color-turquoise);
  }

  .info-icon.closed {
    background: #f5f5f5;
    color: #666;
  }

  .hours-notice {
    text-align: center;
    padding: 16px 20px;
    background: var(--color-turquoise-bg);
    border-radius: 16px;
  }

  .hours-notice p {
    font-size: 0.85rem;
    color: var(--color-text-muted);
    line-height: 1.7;
  }

  @media (max-width: 900px) {
    .hours-layout {
      grid-template-columns: 1fr;
      gap: 32px;
    }

    .calendar-side {
      max-width: 500px;
      margin: 0 auto;
    }

    .info-side {
      max-width: 500px;
      margin: 0 auto;
    }

    .calendar-nav.prev {
      left: -16px;
    }

    .calendar-nav.next {
      right: -16px;
    }
  }

  .sp-only {
    display: none;
  }

  @media (max-width: 768px) {
    .sp-only {
      display: inline;
    }

    .time-value {
      font-size: 1.3rem;
    }

    .monthly-cell {
      padding: 8px 2px;
      min-height: 50px;
    }

    .monthly-cell .date {
      font-size: 0.85rem;
    }

    .monthly-cell .status {
      font-size: 0.75rem;
    }

    .schedule-cell {
      padding: 12px 4px;
    }

    .schedule-cell .day {
      font-size: 0.8rem;
    }

    .schedule-cell .status {
      font-size: 0.9rem;
    }

    .hours-info {
      flex-direction: column;
      align-items: center;
      gap: 10px;
    }

    .hours-notice p {
      text-align: left;
    }

    .calendar-legend {
      flex-direction: row;
      gap: 20px;
    }
  }
</style>

<script>
  let currentMonth = 0;
  const totalMonths = 2;
  const track = document.getElementById('calendarTrack');
  const prevBtn = document.getElementById('prevMonth');
  const nextBtn = document.getElementById('nextMonth');
  const monthTabs = document.querySelectorAll('.month-tab');

  // 6月と7月で切り替える要素
  const hoursJune = document.getElementById('hoursJune');
  const hoursJuly = document.getElementById('hoursJuly');
  const scheduleJune = document.getElementById('scheduleJune');
  const scheduleJuly = document.getElementById('scheduleJuly');
  const infoJune = document.getElementById('infoJune');
  const infoJuly = document.getElementById('infoJuly');
  const newHoursNotice = document.getElementById('newHoursNotice');

  function updateCalendar() {
    // Update calendar position
    if (track) {
      track.style.transform = `translateX(-${currentMonth * 100}%)`;
    }

    // Update navigation buttons
    if (prevBtn) {
      prevBtn.disabled = currentMonth === 0;
      prevBtn.style.opacity = currentMonth === 0 ? '0.3' : '1';
    }

    if (nextBtn) {
      nextBtn.disabled = currentMonth === totalMonths - 1;
      nextBtn.style.opacity = currentMonth === totalMonths - 1 ? '0.3' : '1';
    }

    // Update month tabs
    monthTabs.forEach((tab, index) => {
      if (index === currentMonth) {
        tab.classList.add('active');
      } else {
        tab.classList.remove('active');
      }
    });

    // 6月（currentMonth === 0）と7月（currentMonth === 1）で診療時間・スケジュールを切り替え
    if (currentMonth === 0) {
      // 6月
      hoursJune?.classList.remove('hidden');
      hoursJuly?.classList.add('hidden');
      scheduleJune?.classList.remove('hidden');
      scheduleJuly?.classList.add('hidden');
      infoJune?.classList.remove('hidden');
      infoJuly?.classList.add('hidden');
      newHoursNotice?.classList.add('hidden');
    } else {
      // 7月
      hoursJune?.classList.add('hidden');
      hoursJuly?.classList.remove('hidden');
      scheduleJune?.classList.add('hidden');
      scheduleJuly?.classList.remove('hidden');
      infoJune?.classList.add('hidden');
      infoJuly?.classList.remove('hidden');
      newHoursNotice?.classList.remove('hidden');
    }
  }

  // Arrow button navigation
  if (prevBtn) {
    prevBtn.addEventListener('click', () => {
      if (currentMonth > 0) {
        currentMonth--;
        updateCalendar();
      }
    });
  }

  if (nextBtn) {
    nextBtn.addEventListener('click', () => {
      if (currentMonth < totalMonths - 1) {
        currentMonth++;
        updateCalendar();
      }
    });
  }

  // Month tab navigation
  monthTabs.forEach((tab) => {
    tab.addEventListener('click', () => {
      const monthIndex = parseInt(tab.getAttribute('data-month') || '0');
      currentMonth = monthIndex;
      updateCalendar();
    });
  });

  updateCalendar();
</script>
